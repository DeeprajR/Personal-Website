---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Page Not Found | Deepraj R" description="This page doesn't exist.">
  <div class="h-[80vh] w-full flex flex-col items-center justify-center text-center overflow-hidden">
    
    <!-- Condensed Header Block -->
    <h1 class="text-4xl md:text-5xl font-black uppercase tracking-widest text-black dark:text-white mb-2 leading-none">
      404
    </h1>
    <p class="text-sm md:text-base text-black dark:text-white font-bold mb-6 max-w-sm px-4">
      This page doesn't exist. Play a quick game or head back home.
    </p>

    <!-- TRULY SMALL & CENTERED Game Container (Fixed 240x240) -->
    <div class="relative w-[240px] h-[240px] border-4 border-black dark:border-white bg-white dark:bg-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] touch-none mx-auto mb-10 shrink-0 overflow-hidden">
      <!-- Logic canvas shrunk geometrically and mapped to 15x15 pixel grids -->
      <canvas id="gameCanvas" width="240" height="240" class="w-full h-full block bg-transparent"></canvas>
      
      <!-- Interactive UI Layer -->
      <div id="game-overlay" class="absolute inset-0 flex flex-col items-center justify-center bg-white dark:bg-black z-10 transition-opacity duration-300">
        <h3 id="game-msg" class="text-xl font-black uppercase tracking-wider text-black dark:text-white mb-4 text-center px-4 leading-snug">
          Snake<br/>
          <span class="text-xs font-black tracking-widest uppercase opacity-40">Classic Theme</span>
        </h3>
        <button id="start-btn" class="px-5 py-2 border-2 border-black dark:border-white text-xs font-black tracking-widest uppercase rounded-none text-white dark:text-black bg-black dark:bg-white hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer">
          Play Game
        </button>
      </div>
    </div>

    <!-- Scaled Down CTA -->
    <a href="/" class="inline-flex justify-center items-center px-8 py-3 border-2 border-black dark:border-white text-xs font-black tracking-[0.2em] uppercase rounded-none text-black dark:text-white bg-transparent hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black transition-all duration-300">
      &larr; Return Home
    </a>

  </div>

  <script is:inline>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const overlay = document.getElementById('game-overlay');
    const startBtn = document.getElementById('start-btn');
    const msg = document.getElementById('game-msg');

    // Miniaturized Engine logic (240px square / 15px grid = 16 index)
    const gridSize = 15;
    const tileCount = 16;

    let snake = [];
    let tailLength = 4;
    let dx = 0; let dy = -1;
    let appleX = 8; let appleY = 4;
    let score = 0;
    let gameLoop;
    let isPlaying = false;
    let headX = 8; let headY = 12;

    function initGame() {
      snake = [];
      tailLength = 4;
      dx = 0; dy = -1;
      headX = 8; headY = 12;
      score = 0;
      isPlaying = true;
      overlay.style.opacity = '0';
      setTimeout(() => overlay.style.display = 'none', 300);
      placeApple(); // Seed first feature
      if(gameLoop) clearInterval(gameLoop);
      gameLoop = setInterval(drawGame, 120); 
    }

    function placeApple() {
      // Tightly constrain apple spawn coordinates to NEVER touch outer 0/15 blocks
      appleX = Math.floor(Math.random() * (tileCount - 2)) + 1;
      appleY = Math.floor(Math.random() * (tileCount - 2)) + 1;
      
      // Ensure it doesn't spawn inside user
      for (let segment of snake) {
        if (segment.x === appleX && segment.y === appleY) placeApple();
      }
    }

    function drawGame() {
      headX += dx;
      headY += dy;

      // Outer boundary wall impact
      if (headX < 0 || headX >= tileCount || headY < 0 || headY >= tileCount) {
        return gameOver();
      }

      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Feature extraction (Score points)
      if (headX === appleX && headY === appleY) {
        tailLength++;
        score++;
        placeApple();
      }

      snake.push({x: headX, y: headY});
      while (snake.length > tailLength) {
        snake.shift();
      }

      const isDark = document.documentElement.classList.contains('dark');

      // Apple geometry mapped to mini 15px grid
      ctx.fillStyle = '#ef4444'; 
      ctx.fillRect(appleX * gridSize + 2, appleY * gridSize + 2, gridSize - 4, gridSize - 4);

      // Snake geometry
      ctx.fillStyle = isDark ? '#ffffff' : '#000000';
      for (let i = 0; i < snake.length; i++) {
        // Self-collision impact
        if (i !== snake.length - 1 && snake[i].x === headX && snake[i].y === headY) return gameOver();
        ctx.fillRect(snake[i].x * gridSize + 1, snake[i].y * gridSize + 1, gridSize - 2, gridSize - 2);
      }

      // Tracking numeric text shrunk from 120px to 80px proportionally
      ctx.fillStyle = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
      ctx.font = '900 80px Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(score, canvas.width / 2, canvas.height / 2);
    }

    function gameOver() {
      isPlaying = false;
      clearInterval(gameLoop);
      msg.innerHTML = `Game Over!<br/><span class="text-xs font-medium tracking-normal text-gray-500">Score: ${score}</span>`;
      startBtn.innerText = 'Try Again';
      overlay.style.display = 'flex';
      setTimeout(() => overlay.style.opacity = '1', 10);
    }

    document.addEventListener('keydown', (e) => {
      // Intercept and purge scrolling logic during gameplay only
      if (isPlaying && ['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
        e.preventDefault();
      } else if (isPlaying) return;
      
      // Vector mappings
      if (e.key === 'ArrowUp' && dy !== 1) { dx = 0; dy = -1; }
      if (e.key === 'ArrowDown' && dy !== -1) { dx = 0; dy = 1; }
      if (e.key === 'ArrowLeft' && dx !== 1) { dx = -1; dy = 0; }
      if (e.key === 'ArrowRight' && dx !== -1) { dx = 1; dy = 0; }
    }, {passive: false});

    startBtn.addEventListener('click', initGame);

    // Mobile swipe mapping logic
    let touchStartX = 0; let touchStartY = 0;
    canvas.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, {passive: true});
    canvas.addEventListener('touchmove', e => {
      if(isPlaying) e.preventDefault();
    }, {passive: false});
    canvas.addEventListener('touchend', e => {
      if (!isPlaying) return;
      let moveX = e.changedTouches[0].screenX - touchStartX;
      let moveY = e.changedTouches[0].screenY - touchStartY;
      if(Math.abs(moveX) < 20 && Math.abs(moveY) < 20) return;
      if (Math.abs(moveX) > Math.abs(moveY)) {
        if (moveX > 0 && dx !== -1) { dx = 1; dy = 0; }
        else if (moveX < 0 && dx !== 1) { dx = -1; dy = 0; }
      } else {
        if (moveY > 0 && dy !== -1) { dx = 0; dy = 1; }
        else if (moveY < 0 && dy !== 1) { dx = 0; dy = -1; }
      }
    }, {passive: true});
  </script>
</BaseLayout>
