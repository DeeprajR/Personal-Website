---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const hobbiesEntries = await getCollection('hobbies');
  return hobbiesEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Deepraj R`}>
  <article class="max-w-3xl mx-auto px-6 py-24 md:py-32">
    
    <div class="mb-16 text-center">
      <a href="/hobbies" class="text-xs font-black tracking-widest uppercase text-black dark:text-white opacity-40 hover:opacity-100 mb-12 inline-block transition-all underline underline-offset-4 decoration-2">&larr; Back to Hobbies</a>
      
      <div class="mb-8 flex justify-center gap-3">
        {entry.data.categories?.map((cat: string) => (
          <span class="text-[10px] font-black text-black dark:text-white uppercase tracking-widest border-2 border-black dark:border-white px-3 py-1">{cat}</span>
        ))}
      </div>

      <h1 class="text-4xl md:text-6xl font-black tracking-tighter text-black dark:text-white mb-8 leading-none max-w-2xl mx-auto uppercase">
        {entry.data.title}
      </h1>
      
      <p class="text-lg md:text-2xl text-black dark:text-white font-black max-w-2xl mx-auto opacity-70 leading-tight">
        {entry.data.hook}
      </p>
      
      <div class="mt-12 text-xs font-black uppercase tracking-[0.2em] text-black dark:text-white opacity-40">
        {entry.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </div>
    </div>

    {entry.data.bannerImage && (
      <div class="mb-20 -mx-6 md:-mx-12 border-2 border-black dark:border-white shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] dark:shadow-[12px_12px_0px_0px_rgba(255,255,255,1)] overflow-hidden bg-white dark:bg-black">
        <img 
          src={entry.data.bannerImage} 
          alt={`Banner for ${entry.data.title}`} 
          class="w-full h-[40vh] md:h-[60vh] object-cover grayscale hover:grayscale-0 transition-all duration-700" 
        />
      </div>
    )}

    <div class="content-wrapper prose dark:prose-invert max-w-none mx-auto">
      <style is:global>
        @reference "tailwindcss";
        .content-wrapper :where(h3) {
          @apply text-2xl font-black mt-16 mb-6 tracking-tighter uppercase border-b-2 border-black dark:border-white pb-2;
        }
        .content-wrapper :where(p) {
          @apply text-lg leading-relaxed mb-8 font-bold;
        }
        .content-wrapper :where(img) {
          @apply border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] mb-12 w-full h-auto grayscale transition-all duration-700 hover:grayscale-0;
        }
        .content-wrapper :where(ul) {
          @apply list-disc list-outside ml-5 mb-8 space-y-3 text-lg font-bold;
        }
        .content-wrapper :where(li) {
          @apply pl-2;
        }
        .content-wrapper :where(strong) {
          @apply font-black;
        }
      </style>
      <Content />
    </div>

    {entry.data.tags && (
      <div class="mt-20 pt-10 border-t-2 border-black dark:border-white">
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag: string) => (
            <span class="text-[10px] font-black text-black dark:text-white uppercase tracking-widest border-2 border-black dark:border-white px-3 py-1">{tag}</span>
          ))}
        </div>
      </div>
    )}

  </article>
</BaseLayout>
