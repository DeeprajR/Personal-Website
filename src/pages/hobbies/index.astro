---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allHobbies = await getCollection('hobbies');
allHobbies.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by category
const groupedHobbies = allHobbies.reduce((acc, post) => {
  const categories = post.data.categories && post.data.categories.length > 0 ? post.data.categories : ['Other Explorations'];
  categories.forEach((cat: string) => {
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(post);
  });
  return acc;
}, {} as Record<string, typeof allHobbies>);

const categories = Object.keys(groupedHobbies).sort();

const allPhotography = await getCollection('photography');
allPhotography.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
// Show ALL photos — grid auto-fills columns based on viewport width

const allLibrary = await getCollection('library');
allLibrary.sort((a, b) => a.data.title.localeCompare(b.data.title));
const featuredBooks = allLibrary.slice(0, 4);
---

<BaseLayout title="Hobbies - Deepraj R" description="Explorations in IoT, Cybersecurity, and Photography.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <header class="mb-20 pb-12 border-b-2 border-black dark:border-white">
      <h1 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 text-black dark:text-white uppercase">
        Hobbies & Interests
      </h1>
      <p class="text-lg text-black dark:text-white font-bold max-w-2xl leading-relaxed">
        A dedicated space for my technical explorations and mind space.
      </p>
    </header>

    <!-- Section 1: Categories -->
    <section class="mb-32">
      <h2 class="text-2xl font-black text-black dark:text-white mb-10 pb-4 border-b-2 border-black dark:border-white uppercase tracking-widest">
        Explorations
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {categories.map((category) => (
          <a href={`/hobbies/category/${category.toLowerCase().replace(/\s+/g, '-')}`} class="group block p-8 bg-white dark:bg-black text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] dark:hover:shadow-[12px_12px_0px_0px_rgba(255,255,255,1)] transition-all">
            <h3 class="text-xl font-black mb-3 tracking-tighter uppercase leading-none">
              {category}
            </h3>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] group-hover:opacity-100 transition-all">
              {groupedHobbies[category].length} {groupedHobbies[category].length === 1 ? 'Article' : 'Articles'} &rarr;
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- Section 2: Library -->
    <section class="mb-32">
      <div class="flex justify-between items-center mb-10 pb-4 border-b-2 border-black dark:border-white">
        <h2 class="text-2xl font-black text-black dark:text-white uppercase tracking-widest">
          Library
        </h2>
        <a href="/library" class="text-xs font-black tracking-widest uppercase text-black dark:text-white hover:opacity-100 hover:underline underline-offset-4 decoration-2 transition-all">
          View All &rarr;
        </a>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-8">
        {featuredBooks.map((book) => (
          <a href={book.data.url || '#'} target="_blank" rel="noopener noreferrer" class="block group">
            <div class="aspect-[2/3] bg-white dark:bg-black overflow-hidden mb-6 border-2 border-black dark:border-white shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] group-hover:shadow-[10px_10px_0px_0px_rgba(0,0,0,1)] transition-all duration-300">
              {book.data.coverImage ? (
                <img src={book.data.coverImage} alt={book.data.title} class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105" loading="lazy" />
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center p-6 text-center">
                  <span class="text-[10px] font-black uppercase text-black dark:text-white tracking-widest">{book.data.title}</span>
                </div>
              )}
            </div>
            <h3 class="text-sm font-black text-black dark:text-white uppercase tracking-tight line-clamp-1 mb-1">{book.data.title}</h3>
            <p class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white line-clamp-1">{book.data.author}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Section 3: Photography -->
    <section>
      <div class="flex justify-between items-center mb-10 pb-4 border-b-2 border-black dark:border-white">
        <h2 class="text-2xl font-black text-black dark:text-white uppercase tracking-widest">
          Photography
        </h2>
        <a href="/photography" class="text-xs font-black tracking-widest uppercase text-black dark:text-white hover:opacity-100 hover:underline underline-offset-4 decoration-2 transition-all">
          View All &rarr;
        </a>
      </div>
      
      <div style="columns: 280px; column-gap: 1.5rem;" class="space-y-6">
        {allPhotography.slice(0, 6).map((photo) => (
          <a href={photo.data.image} target="_blank" rel="noopener noreferrer" 
             class="block group relative overflow-hidden bg-white dark:bg-black border-2 border-black dark:border-white break-inside-avoid shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] hover:shadow-[10px_10px_0px_0px_rgba(0,0,0,1)] transition-all duration-300">
            <img 
              src={photo.data.image} 
              alt={photo.data.title}
              class="w-full h-auto object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-x-0 bottom-0 bg-white/95 dark:bg-black/95 p-4 border-t-2 border-black dark:border-white translate-y-full group-hover:translate-y-0 transition-transform duration-300">
              <h3 class="text-black dark:text-white font-black uppercase text-[10px] tracking-widest">{photo.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
