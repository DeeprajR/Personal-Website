---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allHobbies = await getCollection('hobbies');
allHobbies.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by category
const groupedHobbies = allHobbies.reduce((acc, post) => {
  const categories = post.data.categories && post.data.categories.length > 0 ? post.data.categories : ['Other Explorations'];
  categories.forEach((cat: string) => {
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(post);
  });
  return acc;
}, {} as Record<string, typeof allHobbies>);

const categories = Object.keys(groupedHobbies).sort();

const allPhotography = await getCollection('photography');
allPhotography.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
// Show ALL photos — grid auto-fills columns based on viewport width

const allLibrary = await getCollection('library');
allLibrary.sort((a, b) => a.data.title.localeCompare(b.data.title));
const featuredBooks = allLibrary.slice(0, 4);
---

<BaseLayout title="Hobbies - Deepraj R" description="Explorations in IoT, Cybersecurity, and Photography.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <header class="mb-20">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-gray-900 dark:text-gray-100">
        Hobbies & Interests
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl leading-relaxed">
        A dedicated space for my technical explorations and mind space.
      </p>
    </header>

    <!-- Section 1: Categories -->
    <section class="mb-32">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8 pb-4 border-b border-gray-100 dark:border-gray-800">
        Explorations
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map((category) => (
          <a href={`/hobbies/category/${category.toLowerCase().replace(/\s+/g, '-')}`} class="group block p-8 bg-gray-50 dark:bg-gray-900/40 hover:bg-gray-100 dark:hover:bg-gray-900 border border-gray-100 dark:border-gray-800 transition-colors">
            <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white mb-2 tracking-tight">
              {category}
            </h3>
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400 font-mono">
              {groupedHobbies[category].length} {groupedHobbies[category].length === 1 ? 'Article' : 'Articles'} &rarr;
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- Section 2: Library -->
    <section class="mb-32">
      <div class="flex justify-between items-end mb-8 pb-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
          Library
        </h2>
        <a href="/library" class="text-sm font-bold tracking-widest uppercase text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white transition-colors">
          View All &rarr;
        </a>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
        {featuredBooks.map((book) => (
          <a href={book.data.url || '#'} target="_blank" rel="noopener noreferrer" class="block group">
            <div class="aspect-[2/3] bg-gray-100 dark:bg-gray-800 overflow-hidden mb-4 border border-gray-100 dark:border-gray-800 shadow-sm group-hover:shadow-md transition-all duration-300">
              {book.data.coverImage ? (
                <img src={book.data.coverImage} alt={book.data.title} class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105" loading="lazy" />
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center p-4 text-center">
                  <span class="text-xs font-bold font-mono text-gray-400 dark:text-gray-500">{book.data.title}</span>
                </div>
              )}
            </div>
            <h3 class="text-base font-bold text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white transition-colors line-clamp-1">{book.data.title}</h3>
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mt-1 line-clamp-1">{book.data.author}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Section 3: Photography -->
    <section>
      <div class="flex justify-between items-end mb-8 pb-4 border-b border-gray-100 dark:border-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
          Photography
        </h2>
        <a href="/photography" class="text-sm font-bold tracking-widest uppercase text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white transition-colors">
          View All &rarr;
        </a>
      </div>
      
      <!-- Auto-fill masonry: columns auto-count based on min 280px width -->
      <div style="columns: 280px; column-gap: 1.25rem;">
        {allPhotography.map((photo) => (
          <a href={photo.data.image} target="_blank" rel="noopener noreferrer" 
             class="block group relative overflow-hidden bg-gray-100 dark:bg-gray-800 break-inside-avoid mb-5 shadow-sm hover:shadow-md transition-all duration-300">
            <img 
              src={photo.data.image} 
              alt={photo.data.title}
              class="w-full h-auto object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <h3 class="text-white text-sm font-medium">{photo.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
