---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allHobbies = await getCollection('hobbies');
  
  const categories = new Set();
  allHobbies.forEach(post => {
    const postCategories = post.data.categories && post.data.categories.length > 0 ? post.data.categories : ['Other Explorations'];
    postCategories.forEach(cat => categories.add(cat));
  });

  return Array.from(categories).map(category => {
    const catString = category as string;
    return {
      params: { category: catString.toLowerCase().replace(/\s+/g, '-') },
      props: { 
        categoryName: catString,
        posts: allHobbies.filter(post => {
          const postCategories = post.data.categories && post.data.categories.length > 0 ? post.data.categories : ['Other Explorations'];
          return postCategories.includes(catString);
        }).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
      },
    };
  });
}

const { categoryName, posts } = Astro.props;
---

<BaseLayout title={`${categoryName} | Deepraj R`} description={`Articles and explorations in ${categoryName}.`}>
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <div class="mb-16">
      <a href="/hobbies" class="text-sm font-bold tracking-widest uppercase text-gray-400 hover:text-black dark:text-gray-500 dark:hover:text-white mb-12 inline-block transition-colors">&larr; Back to Hobbies</a>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6 text-gray-900 dark:text-gray-100">
        {categoryName}
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl leading-relaxed">
        Showing {posts.length} {posts.length === 1 ? 'article' : 'articles'} in this collection.
      </p>
    </div>

    <div class="space-y-0 border-t border-gray-100 dark:border-gray-800">
      {posts.map((post) => (
        <article class="group relative py-12 border-b border-gray-100 dark:border-gray-800 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-900/30 px-6 -mx-6 transition-colors">
          <a href={`/hobbies/${post.id}`} class="block z-10">
            <time class="text-sm font-bold tracking-widest uppercase text-gray-400 dark:text-gray-500 mb-3 block font-mono">
              {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
            <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white mb-3 transition-colors tracking-tight">
              {post.data.title}
            </h3>
            <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-6 max-w-3xl">
              {post.data.hook}
            </p>
            <div class="flex flex-wrap gap-2">
              {post.data.tags?.map((tag: string) => (
                <span class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest border border-gray-200 dark:border-gray-800 px-3 py-1 bg-white dark:bg-gray-950">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
