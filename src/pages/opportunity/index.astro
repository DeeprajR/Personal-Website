---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const jobsRaw = await getCollection('jobs');
const talentRaw = await getCollection('talent');

const jobs = jobsRaw.sort((a, b) => {
  // Sort by status: active first
  if (a.data.status === 'active' && b.data.status === 'expired') return -1;
  if (a.data.status === 'expired' && b.data.status === 'active') return 1;
  // Then by date descending
  return b.data.dateAdded.valueOf() - a.data.dateAdded.valueOf();
});
const talent = talentRaw.sort((a, b) => b.data.dateAdded.valueOf() - a.data.dateAdded.valueOf());

// Email constants
const CONTACT_EMAIL = "hello@deeprajr.com";

const candidateSubject = encodeURIComponent("Request to be listed on Opportunity Board");
const candidateBody = encodeURIComponent(`Hi Deepraj,

I'd like to be added to the available talent pool.

* Name (Or state "Keep Anonymous"): 
* Headline / Target Role: 
* Years of Experience: 
* Key Skills: 
* LinkedIn Link (Optional): 
* Portfolio Link (Optional): 

Thanks!`);
const candidateMailto = `mailto:${CONTACT_EMAIL}?subject=${candidateSubject}&body=${candidateBody}`;

const companySubject = encodeURIComponent("Request to post Open Role");
const companyBody = encodeURIComponent(`Hi Deepraj,

We'd like to list an open role on the board.

* Company Name (Or state "Keep Anonymous"): 
* Role Title: 
* Location / Remote Policy: 
* Salary Range: 
* Key Skills Required: 

Thanks!`);
const companyMailto = `mailto:${CONTACT_EMAIL}?subject=${companySubject}&body=${companyBody}`;
---

<BaseLayout title="Opportunities | Deepraj R" description="Connecting vetted talent with the right teams.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    
    <!-- Hero -->
    <div class="mb-40">
      <h1 class="text-4xl md:text-6xl font-black tracking-tighter text-black dark:text-white leading-tight mb-4 uppercase">
        Opportunities
      </h1>
      <p class="text-xl text-black dark:text-white max-w-2xl leading-relaxed mb-6 font-bold">
        Connecting vetted talent with the right teams.
      </p>
      
      <!-- Disclaimer Block -->
      <div class="mt-12 bg-white dark:bg-black border-2 border-black dark:border-white shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] p-8 max-w-3xl">
        <div class="flex items-start gap-5">
          <div class="w-8 h-8 flex items-center justify-center border-2 border-black dark:border-white shrink-0 bg-black dark:bg-white text-white dark:text-black">
            <span class="text-xl font-black mt-0.5">!</span>
          </div>
          <div>
            <h3 class="font-black text-black dark:text-white uppercase tracking-tighter mb-2">Please Note</h3>
            <p class="text-sm font-bold text-black dark:text-white leading-relaxed">
              I am not a job provider, recruiter, or an agency. Because people frequently ask me for jobs and companies ask me for talent, I built this board simply to connect seekers and givers who reach out to me.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Open Roles -->
    <section class="mb-40">
      <div class="mb-8 flex items-center gap-6">
        <h2 class="text-2xl font-black tracking-widest uppercase text-black dark:text-white">Roles</h2>
        <div class="h-1 bg-black dark:bg-white flex-grow opacity-20"></div>
        <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white border-2 border-black dark:border-white px-3 py-1">{jobs.length} listed</span>
      </div>

      {jobs.length > 0 ? (
        <div class="grid grid-cols-1 gap-12">
          {jobs.map(job => (
            <div class={`group border-2 border-black dark:border-white p-8 bg-white dark:bg-black text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] flex flex-col md:flex-row md:items-start justify-between gap-8 transition-all hover:translate-y-[-2px] hover:shadow-[10px_10px_0px_0px_rgba(0,0,0,1)] dark:hover:shadow-[10px_10px_0px_0px_rgba(255,255,255,1)] ${job.data.status === 'expired' ? 'grayscale' : ''}`}>
              <div class="flex-grow">
                <div class="flex items-center justify-between gap-4 mb-4 flex-wrap">
                  <div class="flex items-center gap-3">
                    {job.data.status === 'expired' && (
                      <span class="text-[10px] font-black uppercase tracking-widest bg-black dark:bg-white text-white dark:text-black px-2 py-0.5 border-2 border-black dark:border-white group-hover:border-white dark:group-hover:border-black group-hover:bg-white dark:group-hover:bg-black group-hover:text-black dark:group-hover:text-white transition-colors">
                        Expired
                      </span>
                    )}
                    <span class="text-[10px] font-black uppercase tracking-widest border-2 border-black dark:border-white group-hover:border-white dark:group-hover:border-black px-2 py-0.5 group-hover:text-white dark:group-hover:text-black transition-colors">
                      {job.data.workMode}
                    </span>
                    <span class="text-[10px] font-black uppercase tracking-widest border-2 border-black dark:border-white group-hover:border-white dark:group-hover:border-black px-2 py-0.5 group-hover:text-white dark:group-hover:text-black transition-colors">
                      {job.data.employmentType}
                    </span>
                  </div>
                  <span class="text-[10px] font-black uppercase tracking-widest group-hover:opacity-100 group-hover:text-white dark:group-hover:text-black ml-auto transition-all">
                    Listed {job.data.dateAdded.toISOString().split('T')[0]}
                  </span>
                </div>
                <a href={`/opportunity/jobs/${job.id.replace(/\.[^/.]+$/, "")}`}>
                  <h3 class="text-2xl font-black uppercase tracking-tighter hover:underline decoration-4 underline-offset-4 transition-all group-hover:text-white dark:group-hover:text-black">
                    {job.data.title}
                  </h3>
                </a>
                <p class="font-bold mt-2 mb-6 uppercase tracking-widest text-xs group-hover:opacity-100 group-hover:text-white dark:group-hover:text-black transition-all">{job.data.company}</p>
                <div class="flex flex-wrap gap-2">
                  {job.data.skills.map(skill => (
                    <span class="text-[10px] font-black bg-transparent uppercase tracking-widest border border-black dark:border-white group-hover:border-white dark:group-hover:border-black px-2 py-0.5 transition-colors group-hover:text-white dark:group-hover:text-black group-hover:opacity-100">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
              
              <div class="shrink-0 w-full md:w-auto">
                {job.data.status === 'active' ? (
                  <a href={`mailto:${CONTACT_EMAIL}?subject=Referral Request: ${job.data.title} at ${job.data.company}`} 
                    class="block w-full text-center bg-black dark:bg-white text-white dark:text-black font-black text-xs uppercase tracking-widest px-8 py-4 border-2 border-black dark:border-white group-hover:bg-white dark:group-hover:bg-black group-hover:text-black dark:group-hover:text-white group-hover:border-black dark:group-hover:border-white transition-all shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)] active:shadow-none">
                    Get Referred
                  </a>
                ) : (
                  <div class="block w-full text-center border-2 border-black dark:border-white font-black text-xs uppercase tracking-widest px-8 py-4 cursor-not-allowed group-hover:text-white dark:group-hover:text-black group-hover:border-white dark:group-hover:border-black">
                    Closed
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="border-2 border-dashed border-black dark:border-white p-16 text-center bg-white dark:bg-black">
          <p class="text-black dark:text-white font-black uppercase tracking-widest text-sm">No open roles listed.</p>
        </div>
      )}
    </section>

    <!-- Available Talent -->
    <section class="mb-40">
      <div class="mb-8 flex items-center gap-6">
        <h2 class="text-2xl font-black tracking-widest uppercase text-black dark:text-white">Talent</h2>
        <div class="h-1 bg-black dark:bg-white flex-grow opacity-20"></div>
        <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white border-2 border-black dark:border-white px-3 py-1">{talent.length} looking</span>
      </div>

      {talent.length > 0 ? (
        <div class="grid grid-cols-1 gap-12">
          {talent.map(person => (
            <div class="group border-2 border-black dark:border-white p-8 bg-white dark:bg-black text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] flex flex-col gap-8 hover:translate-y-[-2px] hover:shadow-[10px_10px_0px_0px_rgba(0,0,0,1)] dark:hover:shadow-[10px_10px_0px_0px_rgba(255,255,255,1)] transition-all">
              <div class="flex flex-col md:flex-row md:items-start justify-between gap-8">
                <div class="flex-grow">
                  <div class="flex items-center gap-4 mb-3">
                    <span class="text-[10px] font-black uppercase tracking-widest border-2 border-black dark:border-white group-hover:border-white dark:group-hover:border-black px-2 py-0.5 transition-colors group-hover:text-white dark:group-hover:text-black">
                      {person.data.experience}
                    </span>
                    <span class="text-[10px] font-black uppercase tracking-widest group-hover:opacity-100 group-hover:text-white dark:group-hover:text-black ml-auto transition-all">Listed {person.data.dateAdded.toISOString().split('T')[0]}</span>
                  </div>
                  <a href={`/opportunity/talent/${person.id.replace(/\.[^/.]+$/, "")}`}>
                    <h3 class="text-2xl font-black uppercase tracking-tighter hover:underline decoration-4 underline-offset-4 transition-all group-hover:text-white dark:group-hover:text-black">
                      {person.data.name}
                    </h3>
                  </a>
                  <p class="font-bold mt-2 mb-4 leading-relaxed max-w-2xl group-hover:opacity-100 group-hover:text-white dark:group-hover:text-black transition-all">{person.data.headline}</p>
                </div>
                
                <div class="shrink-0 w-full md:w-auto">
                  <a href={`mailto:${CONTACT_EMAIL}?subject=Intro Request: Candidate ${person.id} (${person.data.name})`} class="block w-full text-center border-2 border-black dark:border-white font-black text-xs uppercase tracking-widest px-8 py-4 bg-black dark:bg-white text-white dark:text-black hover:bg-white dark:hover:bg-black hover:text-black dark:hover:text-white hover:border-black dark:hover:border-white transition-all shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)] active:shadow-none">
                    Hire Talent
                  </a>
                </div>
              </div>

              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 pt-6 border-t-2 border-black dark:border-white group-hover:border-white dark:group-hover:border-black transition-colors">
                <div class="flex flex-wrap gap-2">
                  {person.data.skills.map(skill => (
                    <span class="text-[10px] font-black uppercase tracking-widest border border-black dark:border-white group-hover:border-white dark:group-hover:border-black px-2 py-0.5 bg-transparent transition-colors group-hover:text-white dark:group-hover:text-black group-hover:opacity-100">
                      {skill}
                    </span>
                  ))}
                </div>
                
                {(person.data.linkedin || person.data.portfolio) && (
                  <div class="flex items-center gap-6 text-[10px] font-black uppercase tracking-widest mt-4 md:mt-0 group-hover:opacity-100 group-hover:text-white dark:group-hover:text-black transition-all">
                    {person.data.linkedin && (
                      <a href={person.data.linkedin} target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4 transition-all">
                        LinkedIn &nearr;
                      </a>
                    )}
                    {person.data.portfolio && (
                      <a href={person.data.portfolio} target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4 transition-all">
                        Portfolio &nearr;
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="border-2 border-dashed border-black dark:border-white p-16 text-center bg-white dark:bg-black">
          <p class="text-black dark:text-white font-black uppercase tracking-widest text-sm">No candidates listed.</p>
        </div>
      )}
    </section>

    <!-- CTAs (Moved to bottom) -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-24 border-t-2 border-black dark:border-white">
      <!-- For Companies -->
      <div class="p-10 border-2 border-black dark:border-white bg-black dark:bg-white text-white dark:text-black flex flex-col items-start group shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)]">
        <svg class="w-10 h-10 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1v2H9V7zm0 4h1v2H9v-2zm0 4h1v2H9v-2zm3-8h1v2h-1V7zm0 4h1v2h-1v-2zm0 4h1v2h-1v-2zm3-8h1v2h-1V7zm0 4h1v2h-1v-2zm0 4h1v2h-1v-2z" /></svg>
        <h2 class="text-2xl font-black tracking-tighter mb-4 uppercase">Hire</h2>
        <p class="text-sm font-bold mb-10 leading-relaxed flex-grow">
          Share your open roles, and I'll connect you with vetted product and tech talent from my network.
        </p>
        <a href={companyMailto} class="inline-flex justify-center items-center border-2 border-white dark:border-black bg-white dark:bg-black text-black dark:text-white font-black text-xs uppercase tracking-widest px-8 py-4 hover:bg-transparent dark:hover:bg-transparent hover:text-white dark:hover:text-black transition-all w-full md:w-auto">
          Post
        </a>
      </div>

      <!-- For Talent -->
      <div class="p-10 bg-white dark:bg-black border-2 border-black dark:border-white flex flex-col items-start group shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)]">
        <svg class="w-10 h-10 mb-6 text-black dark:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
        <h2 class="text-2xl font-black tracking-tighter text-black dark:text-white mb-4 uppercase">Join</h2>
        <p class="text-sm text-black dark:text-white font-bold mb-10 leading-relaxed flex-grow">
          Send me your profile, and I'll notify you if an opportunity matching your skills comes up.
        </p>
        <a href={candidateMailto} class="inline-flex justify-center items-center border-2 border-black dark:border-white bg-transparent text-black dark:text-white font-black text-xs uppercase tracking-widest px-8 py-4 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all w-full md:w-auto">
          Submit
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
