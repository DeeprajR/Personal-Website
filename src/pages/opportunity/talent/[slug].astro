---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const talentEntries = await getCollection('talent');
  return talentEntries.map(entry => ({
    params: { slug: entry.id.replace(/\.[^/.]+$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Email constants
const CONTACT_EMAIL = "hello@deeprajr.com";
---

<BaseLayout title={`${entry.data.name} | Available Talent`}>
  <article class="max-w-3xl mx-auto px-6 py-24 md:py-32">
    
    <div class="mb-24 border-b-2 border-black dark:border-white pb-16">
      <a href="/opportunity" class="text-[10px] font-black tracking-widest uppercase text-black dark:text-white hover:opacity-100 mb-12 inline-block transition-all underline decoration-2 underline-offset-4">&larr; Back to Board</a>
      
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white border-2 border-black dark:border-white px-3 py-1">
          {entry.data.experience}
        </span>
      </div>

      <h1 class="text-4xl md:text-6xl font-black tracking-tighter text-black dark:text-white mb-4 leading-none uppercase">
        {entry.data.name}
      </h1>
      <p class="text-2xl text-black dark:text-white font-bold mb-12 tracking-tight uppercase leading-relaxed max-w-2xl">{entry.data.headline}</p>

      <div class="flex flex-wrap gap-2 mb-16">
        {entry.data.skills.map(skill => (
          <span class="text-[10px] font-black text-black dark:text-white uppercase tracking-widest border-2 border-black dark:border-white px-4 py-1.5 bg-transparent">
            {skill}
          </span>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-6 pt-12 border-t-2 border-black dark:border-white">
        <a href={`mailto:${CONTACT_EMAIL}?subject=Intro Request: Candidate ${entry.id} (${entry.data.name})`} class="inline-flex justify-center items-center px-10 py-5 border-2 border-black dark:border-white text-[10px] font-black tracking-widest uppercase bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] active:shadow-none translate-y-[-2px] w-full sm:w-auto">
          Interview Candidate
        </a>

        {(entry.data.linkedin || entry.data.portfolio) && (
          <div class="flex items-center gap-6 px-4">
            {entry.data.linkedin && (
              <a href={entry.data.linkedin} target="_blank" rel="noopener noreferrer" class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white hover:underline decoration-2 underline-offset-4 transition-all">
                LinkedIn &nearr;
              </a>
            )}
            {entry.data.portfolio && (
              <a href={entry.data.portfolio} target="_blank" rel="noopener noreferrer" class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white hover:underline decoration-2 underline-offset-4 transition-all">
                Portfolio &nearr;
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <div class="content-wrapper prose prose-neutral dark:prose-invert max-w-none">
      <style is:global>
        @reference "tailwindcss";
        .content-wrapper h2 {
          @apply text-2xl font-black text-black dark:text-white mt-12 mb-6 uppercase tracking-tight;
        }
        .content-wrapper h3 {
          @apply text-xl font-black text-black dark:text-white mt-8 mb-4 uppercase tracking-tight;
        }
        .content-wrapper p {
          @apply text-base text-black dark:text-white leading-relaxed mb-6 font-bold;
        }
        .content-wrapper ul {
          @apply list-disc list-outside ml-5 mb-8 space-y-2 text-black dark:text-white font-bold;
        }
        .content-wrapper li {
          @apply pl-1;
        }
        .content-wrapper strong {
          @apply font-black text-black dark:text-white;
        }
      </style>
      <Content />
    </div>

  </article>
</BaseLayout>
