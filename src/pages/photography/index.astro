---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPhotography = await getCollection('photography');
allPhotography.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Photography - Deepraj R" description="A collection of my recent photographs.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <header class="mb-16">
      <a href="/hobbies" class="text-xs font-black tracking-widest uppercase text-black dark:text-white hover:opacity-100 mb-12 inline-block transition-all underline underline-offset-4 decoration-2">&larr; Back to Hobbies</a>
      <h1 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 text-black dark:text-white uppercase">
        Through the Lens
      </h1>
      <p class="text-lg text-black dark:text-white font-bold max-w-2xl leading-relaxed">
        A collection of moments and perspectives captured over time. 
        Select any image to view it in full resolution.
      </p>
    </header>

    <div class="columns-1 sm:columns-2 md:columns-3 gap-8 space-y-8">
      {allPhotography.map((photo) => (
        <a href={photo.data.image} target="_blank" rel="noopener noreferrer" class="block group relative overflow-hidden bg-white dark:bg-black border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] dark:hover:shadow-[12px_12px_0px_0px_rgba(255,255,255,1)] transition-all duration-300 break-inside-avoid">
          <img 
            src={photo.data.image} 
            alt={photo.data.title}
            class="w-full h-auto object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0"
            loading="lazy"
          />
          <div class="absolute inset-x-0 bottom-0 bg-white/95 dark:bg-black/95 p-4 border-t-2 border-black dark:border-white translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-black dark:text-white font-black uppercase text-xs tracking-widest">{photo.data.title}</h3>
            <time class="text-black dark:text-white font-bold text-[10px] uppercase tracking-widest mt-1 block">{photo.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</time>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
