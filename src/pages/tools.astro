---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tools | Deepraj R" description="A set of free utility tools for product managers, writers, and builders.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    
    <header class="mb-16">
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4 text-black dark:text-white uppercase">
        Tools
      </h1>
      <p class="text-lg text-black dark:text-white font-bold max-w-2xl leading-relaxed">
        A personal set of lightweight utilities I keep coming back to. No sign-ups, no tracking, no bloat.
      </p>
    </header>

    <div id="tools-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 justify-center">


        <!-- ═══════════════════════════════════════════════ -->
        <!-- TOOL 1: Book Details Retriever (Writing)        -->
        <!-- ═══════════════════════════════════════════════ -->
        <section id="book-retriever" class="tool-section group">
          <button class="tool-card w-full text-left p-6 md:p-8 transition-all duration-300 text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black">

            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <h2 class="text-xl font-black uppercase tracking-tight">Book Details Retriever</h2>
              </div>
              <p class="text-sm font-bold group-hover:opacity-100 transition-all">Fetch book metadata and Open Library covers for your library frontmatter.</p>
            </div>
            <div class="mt-4 opacity-40 group-hover:opacity-100 transition-all self-end">
              <svg class="w-5 h-5 transition-transform duration-300 transform group-aria-expanded:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </div>
          </button>
          
          <div class="tool-content hidden opacity-0 transition-opacity duration-300 p-6 md:p-8 pt-0 border-t border-gray-50 dark:border-gray-800/50">
            <div class="max-w-xl">
            <div class="space-y-6">
              <div class="flex flex-col sm:flex-row gap-3">
                <div class="flex-1">
                  <label class="block text-[10px] font-black text-black dark:text-white uppercase tracking-widest mb-2">ISBN Number</label>
                  <input id="isbn-input" type="text" maxlength="17" placeholder="e.g. 9780307886231"
                    class="w-full border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white px-4 py-3 text-sm font-mono transition-colors focus:bg-gray-50 dark:focus:bg-gray-950 focus:outline-none placeholder:text-black/30 dark:placeholder:text-white/30" />
                  <p id="isbn-error" class="text-xs text-red-600 font-black font-mono mt-2 hidden"></p>
                </div>
                <div class="flex items-end">
                  <button id="isbn-fetch" class="w-full sm:w-auto px-8 py-3.5 border-2 border-black dark:border-white text-[11px] font-black uppercase tracking-[0.2em] bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer whitespace-nowrap">
                    Fetch Book
                  </button>
                </div>
              </div>

              <!-- Loading state -->
              <div id="isbn-loading" class="hidden text-xs font-mono font-black text-black dark:text-white animate-pulse uppercase tracking-widest">Fetching from Open Library...</div>

              <!-- Preview + Output -->
              <div id="isbn-result" class="hidden space-y-6">
                <div id="isbn-preview" class="flex gap-4 p-4 border-2 border-black dark:border-white bg-gray-50/50 dark:bg-gray-950/20">
                  <img id="isbn-cover" src="" alt="Cover" class="w-14 h-20 object-cover border-2 border-black dark:border-white shrink-0" />
                  <div>
                    <p id="isbn-book-title" class="font-black text-black dark:text-white text-sm uppercase tracking-tight"></p>
                    <p id="isbn-book-author" class="text-xs text-black dark:text-white font-bold mt-1"></p>
                    <p id="isbn-book-genres" class="text-[10px] text-black dark:text-white font-black font-mono mt-2 uppercase tracking-widest"></p>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between items-center mb-2">
                    <label class="text-[10px] font-black text-black dark:text-white uppercase tracking-widest">Frontmatter Output</label>
                    <button id="isbn-copy" class="text-[10px] font-black tracking-widest uppercase text-black dark:text-white hover:underline transition-all cursor-pointer">Copy HTML →</button>
                  </div>
                  <textarea id="isbn-output" rows="8" readonly
                    class="w-full border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white px-4 py-3 text-xs font-mono focus:outline-none resize-none font-bold"></textarea>
                  <p id="isbn-copy-status" class="text-[10px] font-black font-mono text-emerald-600 dark:text-emerald-400 mt-2 hidden uppercase tracking-widest">✓ Copied to clipboard</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL 2: Markdown Table Generator (Writing) -->
      <section id="markdown-table" class="tool-section group">
        <button class="tool-card w-full text-left p-6 md:p-8 transition-all duration-300 text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h2 class="text-xl font-black uppercase tracking-tight">Markdown Table Generator</h2>
            </div>
            <p class="text-sm font-bold group-hover:opacity-100 transition-all">Convert CSV or spreadsheet data into Markdown tables instantly.</p>
          </div>
          <div class="mt-4 opacity-40 group-hover:opacity-100 transition-all self-end">
            <svg class="w-5 h-5 transition-transform duration-300 transform group-aria-expanded:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </div>
        </button>

        <div class="tool-content hidden opacity-0 transition-opacity duration-300 p-6 md:p-8 pt-0 border-t border-black dark:border-white">
          <div class="max-w-xl">
            <div class="space-y-6">
              <div>
                <label class="block text-[10px] font-black text-black dark:text-white uppercase tracking-widest mb-2">Input Data (CSV or Tab-separated)</label>
                <textarea id="md-table-input" rows="5" placeholder="Name, Role, Location&#10;Alice, PM, London" class="w-full border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white px-4 py-3 text-sm font-mono font-bold transition-colors focus:bg-gray-50 dark:focus:bg-gray-950 focus:outline-none placeholder:text-black/30 dark:placeholder:text-white/30 resize-none"></textarea>
              </div>
              <div class="flex flex-col sm:flex-row items-center gap-4">
                <label class="flex items-center gap-3 cursor-pointer group w-full sm:w-auto">
                  <input type="checkbox" id="md-table-header" checked class="w-4 h-4 accent-black dark:accent-white" />
                  <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white group-hover:opacity-100 transition-all">Use first row as header</span>
                </label>
                <button id="md-table-gen" class="w-full sm:flex-1 py-3.5 border-2 border-black dark:border-white text-[11px] font-black uppercase tracking-[0.2em] bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all cursor-pointer">Generate Table</button>
              </div>
              <div>
                <div class="flex justify-between items-center mb-2">
                  <label class="text-[10px] font-black text-black dark:text-white uppercase tracking-widest">Markdown Output</label>
                  <button id="md-table-copy" class="text-[10px] font-black tracking-widest uppercase text-black dark:text-white hover:underline transition-all cursor-pointer">Copy Table →</button>
                </div>
                <textarea id="md-table-output" rows="6" readonly placeholder="Markdown will appear here..." class="w-full border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white px-4 py-3 text-xs font-mono font-bold focus:outline-none resize-none"></textarea>
                <p id="md-table-status" class="text-[10px] font-black font-mono text-emerald-600 dark:text-emerald-400 mt-2 hidden uppercase tracking-widest">✓ Copied to clipboard</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL 3: Password Generator (Developer) -->
      <section id="password-generator" class="tool-section group">
        <button class="tool-card w-full text-left p-6 md:p-8 transition-all duration-300 text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h2 class="text-xl font-black uppercase tracking-tight">Password Generator</h2>
            </div>
            <p class="text-sm font-bold group-hover:opacity-100 transition-all">Generate secure, random passwords locally using cryptographically strong random values.</p>
          </div>
          <div class="mt-4 opacity-40 group-hover:opacity-100 transition-all self-end">
            <svg class="w-5 h-5 transition-transform duration-300 transform group-aria-expanded:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </div>
        </button>

        <div class="tool-content hidden opacity-0 transition-opacity duration-300 p-6 md:p-8 pt-0 border-t border-black dark:border-white">
          <div class="max-w-xl">
            <div class="space-y-8">
              <div>
                <div class="flex justify-between items-center mb-4">
                  <label class="text-[10px] font-black text-black dark:text-white uppercase tracking-widest">Password Length: <span id="pw-length-val" class="text-black dark:text-white font-black font-mono ml-2">16</span></label>
                </div>
                <input id="pw-length" type="range" min="8" max="64" value="16" class="w-full h-2 bg-black/10 dark:bg-white/10 rounded-none appearance-none cursor-pointer accent-black dark:accent-white" />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox" id="pw-upper" checked class="w-4 h-4 rounded-none border-2 border-black dark:border-white text-black dark:text-white accent-black dark:accent-white" />
                  <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white group-hover:opacity-100 transition-all">Uppercase</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox" id="pw-lower" checked class="w-4 h-4 rounded-none border-2 border-black dark:border-white text-black dark:text-white accent-black dark:accent-white" />
                  <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white group-hover:opacity-100 transition-all">Lowercase</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox" id="pw-numbers" checked class="w-4 h-4 rounded-none border-2 border-black dark:border-white text-black dark:text-white accent-black dark:accent-white" />
                  <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white group-hover:opacity-100 transition-all">Numbers</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox" id="pw-symbols" class="w-4 h-4 rounded-none border-2 border-black dark:border-white text-black dark:text-white accent-black dark:accent-white" />
                  <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white group-hover:opacity-100 transition-all">Special</span>
                </label>
              </div>

              <div class="space-y-4">
                <div class="relative group">
                  <input id="pw-output" type="text" readonly 
                    class="w-full border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white px-4 py-4 text-lg font-mono font-black tracking-wider focus:outline-none" />
                  <div class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-1">
                    <button id="pw-refresh" class="p-2 text-black dark:text-white opacity-40 hover:opacity-100 transition-all" title="Regenerate">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                    </button>
                    <div class="w-px h-4 bg-black/10 dark:bg-white/10 mx-1"></div>
                    <button id="pw-copy-btn" class="px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-black dark:text-white hover:underline transition-all">Copy</button>
                  </div>
                </div>
                <p id="pw-status" class="text-[10px] text-center font-black font-mono text-emerald-600 dark:text-emerald-400 uppercase tracking-widest hidden">✓ Securely copied to clipboard</p>
              </div>
            </div>
          </div>
        </div>
      </section>


      <!-- TOOL 4: Image Converter (Media) -->
      <section id="image-converter" class="tool-section group">
        <button class="tool-card w-full text-left p-6 md:p-8 transition-all duration-300 text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h2 class="text-xl font-black uppercase tracking-tight">Image Converter</h2>
            </div>
            <p class="text-sm font-bold group-hover:opacity-100 transition-all">Offline, secure batch image conversion to WebP, PNG, or JPEG.</p>
          </div>
          <div class="mt-4 opacity-40 group-hover:opacity-100 transition-all self-end">
            <svg class="w-5 h-5 transition-transform duration-300 transform group-aria-expanded:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </div>
        </button>

        <div class="tool-content hidden opacity-0 transition-opacity duration-300 p-6 md:p-8 pt-0 border-t border-black dark:border-white">
          <div class="max-w-xl">
            <div class="space-y-6">
              <!-- Drop Zone -->
              <div id="drop-zone" class="border-2 border-dashed border-black/10 dark:border-white/10 bg-white dark:bg-black p-12 text-center transition-all hover:border-black dark:hover:border-white">
                <input type="file" id="img-input" multiple accept="image/*" class="hidden" />
                <label for="img-input" class="cursor-pointer">
                  <svg class="w-8 h-8 mx-auto text-black dark:text-white opacity-20 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  <p class="text-xs font-black text-black dark:text-white uppercase tracking-widest">Drop images here or <span class="underline underline-offset-4">browse</span></p>
                </label>
              </div>

              <!-- Options (Hidden initially) -->
              <div id="img-options" class="hidden space-y-4 animate-in fade-in slide-in-from-top-2">
                <div class="flex flex-col sm:flex-row items-center gap-4">
                  <div class="flex-1 w-full">
                    <label class="block text-[10px] font-black text-black dark:text-white uppercase tracking-widest mb-2">Target Format</label>
                    <select id="img-format" class="w-full border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white px-4 py-3 text-sm font-mono font-bold transition-colors focus:bg-gray-50 dark:focus:bg-gray-950 focus:outline-none cursor-pointer">
                      <option value="image/webp" selected>WEB P (Best Quality)</option>
                      <option value="image/png">P N G</option>
                      <option value="image/jpeg">J P E G</option>
                    </select>
                  </div>
                  <button id="convert-all" class="w-full sm:w-auto px-8 py-3.5 border-2 border-black dark:border-white text-[11px] font-black uppercase tracking-[0.2em] bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
                    Download All
                  </button>
                </div>
                
                <div id="img-list" class="space-y-2 max-h-60 overflow-y-auto pr-2 custom-scrollbar">
                  <!-- File cards will be injected here -->
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

    </div> <!-- End of #tools-container -->
  </div> <!-- End of outer layout container -->

  <script is:inline>
    // ── Accordion Logic ──────────────────────────────────────────
    function initAccordion() {
      const sections = document.querySelectorAll('.tool-section');
      const buttons = document.querySelectorAll('.tool-card');

      function closeAll() {
        sections.forEach(s => {
          s.classList.remove('is-active');
          s.querySelector('.tool-card').setAttribute('aria-expanded', 'false');
          const content = s.querySelector('.tool-content');
          content.classList.add('hidden');
          content.classList.remove('opacity-100');
        });
      }

      function openTool(id) {
        const target = document.getElementById(id.replace('#', ''));
        if (!target) return;
        
        closeAll();
        target.classList.add('is-active');
        const card = target.querySelector('.tool-card');
        card.setAttribute('aria-expanded', 'true');
        const content = target.querySelector('.tool-content');
        content.classList.remove('hidden');
        setTimeout(() => content.classList.add('opacity-100'), 10);
        
        // Scroll to tool after a short delay for grid re-flow
        setTimeout(() => {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 150);
      }

      buttons.forEach(btn => {
        btn.onclick = (e) => {
          const section = btn.closest('.tool-section');
          const isActive = section.classList.contains('is-active');
          const id = section.id;
          
          if (isActive) {
            closeAll();
            history.replaceState(null, null, ' '); // Clear hash
          } else {
            openTool(id);
            history.replaceState(null, null, `#${id}`);
          }
        };
      });

      // Handle sidebar & deep links
      window.addEventListener('hashchange', () => {
        if (window.location.hash) openTool(window.location.hash);
      });

      // Initial state
      if (window.location.hash) {
        openTool(window.location.hash);
      } else {
        // Expand first tool by default?
        // openTool('book-retriever');
      }
    }

    initAccordion();

    // ── Book Details Retriever (ISBN) ─────────────────────────────
    function validateISBN(raw) {
      const cleaned = raw.replace(/[\s\-]/g, '');
      if (cleaned.length === 10) {
        if (!/^[0-9]{9}[0-9X]$/.test(cleaned)) return null;
        let sum = 0;
        for (let i = 0; i < 9; i++) sum += (10 - i) * parseInt(cleaned[i]);
        const check = cleaned[9] === 'X' ? 10 : parseInt(cleaned[9]);
        sum += check;
        return sum % 11 === 0 ? cleaned : null;
      }
      if (cleaned.length === 13) {
        if (!/^97[89][0-9]{10}$/.test(cleaned)) return null;
        let sum = 0;
        for (let i = 0; i < 12; i++) sum += parseInt(cleaned[i]) * (i % 2 === 0 ? 1 : 3);
        const check = (10 - (sum % 10)) % 10;
        return parseInt(cleaned[12]) === check ? cleaned : null;
      }
      return null;
    }

    document.getElementById('isbn-fetch').addEventListener('click', async () => {
      const raw = document.getElementById('isbn-input').value.trim();
      const errEl = document.getElementById('isbn-error');
      const loadEl = document.getElementById('isbn-loading');
      const resultEl = document.getElementById('isbn-result');

      errEl.classList.add('hidden');
      resultEl.classList.add('hidden');

      const isbn = validateISBN(raw);
      if (!isbn) {
        errEl.textContent = raw.length === 0
          ? '✗ Please enter an ISBN number.'
          : `✗ "${raw}" is not a valid ISBN-10 or ISBN-13 (check digit mismatch or wrong format).`;
        errEl.classList.remove('hidden');
        return;
      }

      loadEl.classList.remove('hidden');
      try {
        const url = `https://openlibrary.org/api/books?bibkeys=ISBN:${isbn}&format=json&jscmd=data`;
        const resp = await fetch(url);
        const data = await resp.json();
        const book = data[`ISBN:${isbn}`];

        if (!book) {
          loadEl.classList.add('hidden');
          errEl.textContent = `✗ No book found for ISBN ${isbn}. Try the other format (ISBN-10 vs ISBN-13).`;
          errEl.classList.remove('hidden');
          return;
        }

        const title    = book.title || 'Unknown Title';
        const author   = book.authors ? book.authors.map(a => a.name).join(', ') : 'Unknown Author';
        const coverUrl = book.cover?.large || book.cover?.medium || `https://covers.openlibrary.org/b/isbn/${isbn}-L.jpg`;
        const bookUrl  = `https://openlibrary.org/isbn/${isbn}`;
        const today    = new Date().toISOString().split('T')[0];
        const subjects = book.subjects ? book.subjects.map(s => (s.name || s).toLowerCase()) : [];
        let genres = subjects.map(s => {
          if (s.includes('self-help') || s.includes('improvement')) return 'Self-Improvement';
          if (s.includes('business') || s.includes('productivity') || s.includes('time')) return 'Productivity';
          if (s.includes('psychology') || s.includes('behavior') || s.includes('social')) return 'Psychology';
          if (s.includes('philosophy') || s.includes('spirituality') || s.includes('mind') || s.includes('religion')) return 'Mindset';
          if (s.includes('fiction') || s.includes('novel')) return 'Fiction';
          if (s.includes('technology') || s.includes('computer') || s.includes('hacking')) return 'Technology';
          if (s.includes('science') || s.includes('nature')) return 'Science';
          return null;
        }).filter(Boolean);
        genres = [...new Set(genres)];
        if (genres.length === 0) {
          // Fallback to top subjects if no match, capitalized
          genres = book.subjects ? book.subjects.slice(0, 1).map(s => {
            const n = s.name || s;
            return n.charAt(0).toUpperCase() + n.slice(1);
          }) : ['Non-Fiction'];
        }
        const genreList = genres.map(g => `"${g}"`).join(', ');
        const markdown = `---\ntitle: "${title}"\nauthor: "${author}"\ncoverImage: "${coverUrl}"\nurl: "${bookUrl}"\ndateAdded: ${today}\ngenres: [${genreList}]\n---`;

        document.getElementById('isbn-book-title').textContent  = title;
        document.getElementById('isbn-book-author').textContent = author;
        document.getElementById('isbn-book-genres').textContent = genres.join(' · ');
        document.getElementById('isbn-cover').src = coverUrl;
        document.getElementById('isbn-output').value = markdown;

        loadEl.classList.add('hidden');
        resultEl.classList.remove('hidden');
      } catch (err) {
        loadEl.classList.add('hidden');
        errEl.textContent = '✗ Network error. Please check your connection and try again.';
        errEl.classList.remove('hidden');
      }
    });

    document.getElementById('isbn-input').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('isbn-fetch').click();
    });

    document.getElementById('isbn-copy').addEventListener('click', () => {
      const out = document.getElementById('isbn-output').value;
      if (!out) return;
      navigator.clipboard.writeText(out).then(() => {
        const s = document.getElementById('isbn-copy-status');
        s.classList.remove('hidden');
        setTimeout(() => s.classList.add('hidden'), 2000);
      });
    });

    // ── Password Generator ────────────────────────────────────────
    const charset = {
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lower: 'abcdefghijklmnopqrstuvwxyz',
      numbers: '0123456789',
      symbols: '!@#$%^&*()_+~`|}{[]:;?><,./-='
    };

    function generatePassword() {
      const length = parseInt(document.getElementById('pw-length').value);
      let chars = '';
      if (document.getElementById('pw-upper').checked) chars += charset.upper;
      if (document.getElementById('pw-lower').checked) chars += charset.lower;
      if (document.getElementById('pw-numbers').checked) chars += charset.numbers;
      if (document.getElementById('pw-symbols').checked) chars += charset.symbols;
      
      if (!chars) {
        document.getElementById('pw-output').value = 'Select at least one set';
        return;
      }

      let password = '';
      const array = new Uint32Array(length);
      window.crypto.getRandomValues(array);
      for (let i = 0; i < length; i++) {
        password += chars[array[i] % chars.length];
      }
      document.getElementById('pw-output').value = password;
    }

    document.getElementById('pw-length').addEventListener('input', (e) => {
      document.getElementById('pw-length-val').textContent = e.target.value;
      generatePassword();
    });
    ['pw-upper', 'pw-lower', 'pw-numbers', 'pw-symbols'].forEach(id => {
      document.getElementById(id).addEventListener('change', generatePassword);
    });
    document.getElementById('pw-refresh').addEventListener('click', generatePassword);
    document.getElementById('pw-copy-btn').addEventListener('click', () => {
      const val = document.getElementById('pw-output').value;
      if (!val || val === 'Select at least one set') return;
      navigator.clipboard.writeText(val).then(() => {
        const s = document.getElementById('pw-status');
        s.classList.remove('hidden');
        setTimeout(() => s.classList.add('hidden'), 2000);
      });
    });
    generatePassword(); // Initial call

    // ── Batch Image Converter ──────────────────────────────────────
    const imgInput = document.getElementById('img-input');
    const imgList = document.getElementById('img-list');
    const imgFormatSelect = document.getElementById('img-format');
    const convertAllBtn = document.getElementById('convert-all');
    const dropZone = document.getElementById('drop-zone');
    const imgOptions = document.getElementById('img-options');
    let convertedFiles = [];
    let currentInputFiles = [];
    let objectUrls = [];

    async function handleFiles(files) {
      if (files.length === 0) return;
      currentInputFiles = files;
      
      // Cleanup previous URLs
      objectUrls.forEach(url => URL.revokeObjectURL(url));
      objectUrls = [];
      
      imgList.innerHTML = '';
      convertedFiles = [];
      convertAllBtn.disabled = true;
      imgOptions.classList.remove('hidden');

      const targetFormatLabel = imgFormatSelect.options[imgFormatSelect.selectedIndex].text.split('(')[0].trim();

      for (const file of files) {
        if (!file.type.startsWith('image/')) continue;

        const card = document.createElement('div');
        card.className = 'p-4 border-2 border-black dark:border-white bg-white dark:bg-black flex items-center justify-between gap-4 animate-in fade-in slide-in-from-bottom-2';
        card.innerHTML = `
          <div class="flex-1 min-w-0">
            <p class="file-name text-sm font-black text-black dark:text-white truncate uppercase tracking-tight">${file.name}</p>
            <div class="flex items-center gap-2 mt-1">
              <p class="file-size text-[10px] text-black dark:text-white font-black font-mono uppercase tracking-widest">${(file.size / 1024).toFixed(1)} KB</p>
              <span class="text-[10px] text-black dark:text-white opacity-20">|</span>
              <p class="conversion-status text-[10px] text-emerald-500 font-black uppercase tracking-widest animate-pulse">Converting to ${targetFormatLabel}...</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="status-indicator w-2.5 h-2.5 rounded-full bg-black/10 dark:bg-white/10 animate-pulse"></div>
            <button class="download-btn hidden px-4 py-2 border-2 border-black dark:border-white text-[10px] font-black uppercase tracking-widest bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer">Save</button>
          </div>
        `;
        imgList.appendChild(card);

        try {
          const targetType = imgFormatSelect.value;
          const blob = await convertImage(file, targetType);
          const extension = targetType.split('/')[1];
          const newName = file.name.split('.')[0] + '.' + (extension === 'jpeg' ? 'jpg' : extension);
          const url = URL.createObjectURL(blob);
          objectUrls.push(url);
          
          convertedFiles.push({ url, name: newName });
          
          const indicator = card.querySelector('.status-indicator');
          indicator.classList.remove('bg-gray-300', 'animate-pulse');
          indicator.classList.add('bg-green-500');

          // Update UI with converted details
          const nameEl = card.querySelector('.file-name');
          const sizeEl = card.querySelector('.file-size');
          const statusEl = card.querySelector('.conversion-status');
          
          nameEl.textContent = newName;
          sizeEl.textContent = `${(blob.size / 1024).toFixed(1)} KB`;
          statusEl.textContent = 'Ready';
          statusEl.classList.remove('animate-pulse', 'text-emerald-500');
          statusEl.classList.add('text-black', 'dark:text-white');
          
          const btn = card.querySelector('.download-btn');
          btn.classList.remove('hidden');
          btn.onclick = () => {
            const a = document.createElement('a');
            a.href = url;
            a.download = newName;
            a.click();
          };
        } catch (err) {
          console.error('Conversion error:', err);
          const indicator = card.querySelector('.status-indicator');
          indicator.classList.remove('bg-gray-300', 'animate-pulse');
          indicator.classList.add('bg-red-500');
          card.querySelector('.conversion-status').textContent = 'Error';
          card.querySelector('.conversion-status').classList.remove('text-emerald-500', 'animate-pulse');
          card.querySelector('.conversion-status').classList.add('text-red-500');
        }
      }

      if (convertedFiles.length > 0) {
        convertAllBtn.disabled = false;
      }
    }

    imgInput.addEventListener('change', (e) => handleFiles(Array.from(e.target.files)));

    imgFormatSelect.addEventListener('change', () => {
      if (currentInputFiles.length > 0) {
        handleFiles(currentInputFiles);
      }
    });

    // Drag-and-drop handlers
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault();
        e.stopPropagation();
      }, false);
    });

    ['dragenter', 'dragover'].forEach(eventName => {
      dropZone.addEventListener(eventName, () => dropZone.classList.add('border-black', 'dark:border-white'), false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, () => dropZone.classList.remove('border-black', 'dark:border-white'), false);
    });

    dropZone.addEventListener('drop', (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      handleFiles(Array.from(files));
    }, false);

    convertAllBtn.addEventListener('click', () => {
      convertedFiles.forEach((file, index) => {
        setTimeout(() => {
          const a = document.createElement('a');
          a.href = file.url;
          a.download = file.name;
          a.click();
        }, index * 200);
      });
    });

    function convertImage(file, targetType) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0);
            canvas.toBlob((blob) => {
              if (blob) resolve(blob);
              else reject(new Error('Canvas toBlob failed'));
            }, targetType, 0.9);
          };
          img.onerror = () => reject(new Error('Image metadata error'));
          img.src = e.target.result;
        };
        reader.onerror = () => reject(new Error('File load error'));
        reader.readAsDataURL(file);
      });
    }
    // ── Markdown Table Generator ────────────────────────────────
    document.getElementById('md-table-gen').addEventListener('click', () => {
      const input = document.getElementById('md-table-input').value.trim();
      if (!input) return;

      const lines = input.split('\n');
      const data = lines.map(line => {
        if (line.includes('\t')) return line.split('\t');
        if (line.includes(',')) return line.split(',').map(s => s.trim());
        return [line];
      });

      const maxCols = Math.max(...data.map(row => row.length));
      let markdown = '';
      
      data.forEach((row, i) => {
        const paddedRow = row.concat(Array(maxCols - row.length).fill(''));
        markdown += '| ' + paddedRow.join(' | ') + ' |\n';
        if (i === 0 && document.getElementById('md-table-header').checked) {
          markdown += '| ' + Array(maxCols).fill('---').join(' | ') + ' |\n';
        }
      });

      document.getElementById('md-table-output').value = markdown;
    });

    document.getElementById('md-table-copy').addEventListener('click', () => {
      const val = document.getElementById('md-table-output').value;
      if (!val) return;
      navigator.clipboard.writeText(val).then(() => {
        const s = document.getElementById('md-table-status');
        s.classList.remove('hidden');
        setTimeout(() => s.classList.add('hidden'), 2000);
      });
    });
  </script>

  <style>
    /* Premium Grid logic */
    #tools-container {
      display: grid;
      grid-template-columns: repeat(1, 1fr);
    }
    
    @media (min-width: 768px) {
      #tools-container {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (min-width: 1024px) {
      #tools-container {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .tool-section {
      scroll-margin-top: 100px;
      background: #ffffff;
      border: 2px solid #000000;
      border-radius: 0;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
    }
    
    :global(.dark) .tool-section {
      background: #000000;
      border-color: #ffffff;
    }

    .tool-section:hover {
      background: #ffffff;
      transform: translate(-4px, -4px);
      box-shadow: 8px 8px 0px 0px #000000;
    }
    
    .tool-section:hover .tool-card {
      background: #000000;
      color: #ffffff;
    }

    :global(.dark) .tool-section:hover {
      background: #000000;
      box-shadow: 8px 8px 0px 0px #ffffff;
    }

    :global(.dark) .tool-section:hover .tool-card {
      background: #ffffff;
      color: #000000;
    }

    .tool-section.is-active {
      grid-column: 1 / -1 !important;
      overflow: visible !important;
      height: auto !important;
      background: #ffffff !important;
      transform: translate(0) !important;
      box-shadow: none !important;
      animation: expand-row 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    :global(.dark) .tool-section.is-active {
      background: #000000 !important;
    }

    /* Centering the 7th item if it's alone in a 3-column grid */
    @media (min-width: 1024px) {
      .tool-section:last-child:nth-child(3n+1):not(.is-active) {
         grid-column: 2; /* Center in the middle column */
      }
    }
    
    /* Centering the 7th item if it's alone in a 2-column grid */
    @media (min-width: 768px) and (max-width: 1023px) {
      .tool-section:last-child:nth-child(even):not(.is-active) {
         grid-column: 1 / span 2;
         max-width: 400px;
         justify-self: center;
         width: 100%;
      }
    }

    @keyframes expand-row {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #e5e7eb;
      border-radius: 10px;
    }
    :global(.dark) .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #475569;
    }
  </style>
</BaseLayout>
