---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tools | Deepraj R" description="A set of free utility tools for product managers, writers, and builders.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    
    <header class="mb-16">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-gray-900 dark:text-gray-100">
        Tools
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl leading-relaxed">
        A personal set of lightweight utilities I keep coming back to. No sign-ups, no tracking, no bloat.
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <!-- ═══════════════════════════════════════════════ -->
      <!-- TOOL 1: Book Details Retriever                   -->
      <!-- ═══════════════════════════════════════════════ -->
      <div class="border border-gray-200 dark:border-gray-800 p-8 bg-gray-50 dark:bg-gray-900/40 lg:col-span-2">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Book Details Retriever</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Enter an ISBN-10 or ISBN-13 to fetch book details and generate a ready-to-paste library frontmatter block.</p>
          </div>
          <span class="text-xs font-bold tracking-widest uppercase text-gray-400 border border-gray-200 dark:border-gray-700 px-2 py-1">Library</span>
        </div>
        <div class="space-y-4">
          <div class="flex gap-3">
            <div class="flex-1">
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">ISBN Number</label>
              <input id="isbn-input" type="text" maxlength="17" placeholder="e.g. 9780307886231 or 0307886239"
                class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
              <p id="isbn-error" class="text-xs text-red-500 font-mono mt-1 hidden"></p>
            </div>
            <div class="flex items-end">
              <button id="isbn-fetch" class="px-6 py-2 border-2 border-black dark:border-white text-xs font-bold tracking-widest uppercase bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer whitespace-nowrap">
                Fetch Book
              </button>
            </div>
          </div>

          <!-- Loading state -->
          <div id="isbn-loading" class="hidden text-sm font-mono text-gray-400 dark:text-gray-500 animate-pulse">Fetching from Open Library...</div>

          <!-- Preview + Output -->
          <div id="isbn-result" class="hidden space-y-4">
            <div id="isbn-preview" class="flex gap-4 p-4 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
              <img id="isbn-cover" src="" alt="Cover" class="w-14 h-20 object-cover border border-gray-100 dark:border-gray-800 shrink-0" />
              <div>
                <p id="isbn-book-title" class="font-bold text-gray-900 dark:text-white text-sm"></p>
                <p id="isbn-book-author" class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"></p>
                <p id="isbn-book-genres" class="text-xs text-gray-400 dark:text-gray-500 font-mono mt-1"></p>
              </div>
            </div>
            <div>
              <div class="flex justify-between items-center mb-1">
                <label class="text-xs font-bold text-gray-500 uppercase tracking-widest">Frontmatter Output</label>
                <button id="isbn-copy" class="text-xs font-bold tracking-widest uppercase text-gray-500 hover:text-black dark:hover:text-white transition-colors cursor-pointer">Copy →</button>
              </div>
              <textarea id="isbn-output" rows="10" readonly
                class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none resize-none"></textarea>
              <p id="isbn-copy-status" class="text-xs font-mono text-green-600 dark:text-green-400 mt-1 hidden">✓ Copied to clipboard!</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- TOOL 2: RICE Score Calculator                    -->
      <!-- ═══════════════════════════════════════════════ -->
      <div class="border border-gray-200 dark:border-gray-800 p-8 bg-gray-50 dark:bg-gray-900/40">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">RICE Score Calculator</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Prioritize features using Reach × Impact × Confidence ÷ Effort</p>
          </div>
          <span class="text-xs font-bold tracking-widest uppercase text-gray-400 border border-gray-200 dark:border-gray-700 px-2 py-1">PM</span>
        </div>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Reach / mo</label>
              <input id="rice-reach" type="number" min="0" placeholder="e.g. 1000" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Impact (0.25–3)</label>
              <select id="rice-impact" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors cursor-pointer">
                <option value="3">3 — Massive</option>
                <option value="2" selected>2 — High</option>
                <option value="1">1 — Medium</option>
                <option value="0.5">0.5 — Low</option>
                <option value="0.25">0.25 — Minimal</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Confidence %</label>
              <input id="rice-confidence" type="number" min="1" max="100" placeholder="e.g. 80" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Effort (person-weeks)</label>
              <input id="rice-effort" type="number" min="0.1" step="0.5" placeholder="e.g. 2" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
            </div>
          </div>
          <button id="rice-calc" class="w-full py-2.5 border-2 border-black dark:border-white text-xs font-bold tracking-widest uppercase bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer">
            Calculate Score
          </button>
          <div id="rice-result" class="hidden border border-gray-200 dark:border-gray-700 p-4 text-center">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">RICE Score</p>
            <p id="rice-score" class="text-4xl font-black text-gray-900 dark:text-white font-mono"></p>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- TOOL 3: Meeting Cost Calculator                  -->
      <!-- ═══════════════════════════════════════════════ -->
      <div class="border border-gray-200 dark:border-gray-800 p-8 bg-gray-50 dark:bg-gray-900/40">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Meeting Cost Calculator</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Find out how much that recurring meeting actually costs.</p>
          </div>
          <span class="text-xs font-bold tracking-widest uppercase text-gray-400 border border-gray-200 dark:border-gray-700 px-2 py-1">PM</span>
        </div>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Attendees</label>
              <input id="meet-attendees" type="number" min="1" placeholder="e.g. 6" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Avg. Salary (₹ LPA)</label>
              <input id="meet-salary" type="number" min="1" placeholder="e.g. 18" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Duration (minutes)</label>
              <input id="meet-duration" type="number" min="1" placeholder="e.g. 60" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Frequency / week</label>
              <input id="meet-freq" type="number" min="1" placeholder="e.g. 3" class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors" />
            </div>
          </div>
          <button id="meet-calc" class="w-full py-2.5 border-2 border-black dark:border-white text-xs font-bold tracking-widest uppercase bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer">
            Calculate Cost
          </button>
          <div id="meet-result" class="hidden border border-gray-200 dark:border-gray-700 p-4">
            <div class="grid grid-cols-3 text-center gap-2">
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Per Meeting</p>
                <p id="meet-per" class="text-xl font-black text-gray-900 dark:text-white font-mono"></p>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Per Month</p>
                <p id="meet-month" class="text-xl font-black text-gray-900 dark:text-white font-mono"></p>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Per Year</p>
                <p id="meet-year" class="text-xl font-black text-gray-900 dark:text-white font-mono"></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- TOOL 4: Reading Time Estimator                   -->
      <!-- ═══════════════════════════════════════════════ -->
      <div class="border border-gray-200 dark:border-gray-800 p-8 bg-gray-50 dark:bg-gray-900/40">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Reading Time Estimator</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Paste any text to get word count and estimated reading time.</p>
          </div>
          <span class="text-xs font-bold tracking-widest uppercase text-gray-400 border border-gray-200 dark:border-gray-700 px-2 py-1">Writing</span>
        </div>
        <div class="space-y-4">
          <textarea id="read-text" rows="6" placeholder="Paste your text here..." class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors resize-none"></textarea>
          <div class="grid grid-cols-3 gap-2 text-center">
            <div class="border border-gray-200 dark:border-gray-700 p-3">
              <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Words</p>
              <p id="read-words" class="text-2xl font-black text-gray-900 dark:text-white font-mono">0</p>
            </div>
            <div class="border border-gray-200 dark:border-gray-700 p-3">
              <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Characters</p>
              <p id="read-chars" class="text-2xl font-black text-gray-900 dark:text-white font-mono">0</p>
            </div>
            <div class="border border-gray-200 dark:border-gray-700 p-3">
              <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Read Time</p>
              <p id="read-time" class="text-2xl font-black text-gray-900 dark:text-white font-mono">0m</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- TOOL 5: JSON Formatter                           -->
      <!-- ═══════════════════════════════════════════════ -->
      <div class="border border-gray-200 dark:border-gray-800 p-8 bg-gray-50 dark:bg-gray-900/40">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">JSON Formatter</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Paste minified JSON to pretty-print and validate it instantly.</p>
          </div>
          <span class="text-xs font-bold tracking-widest uppercase text-gray-400 border border-gray-200 dark:border-gray-700 px-2 py-1">Dev</span>
        </div>
        <div class="space-y-3">
          <textarea id="json-input" rows="5" placeholder='{"key":"value","arr":[1,2,3]}' class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-black dark:focus:border-white transition-colors resize-none"></textarea>
          <div class="flex gap-2">
            <button id="json-format" class="flex-1 py-2.5 border-2 border-black dark:border-white text-xs font-bold tracking-widest uppercase bg-black dark:bg-white text-white dark:text-black hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer">Format</button>
            <button id="json-minify" class="flex-1 py-2.5 border-2 border-gray-400 dark:border-gray-600 text-xs font-bold tracking-widest uppercase text-gray-600 dark:text-gray-400 hover:border-black dark:hover:border-white hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer">Minify</button>
            <button id="json-copy" class="px-4 py-2.5 border-2 border-gray-400 dark:border-gray-600 text-xs font-bold tracking-widest uppercase text-gray-600 dark:text-gray-400 hover:border-black dark:hover:border-white hover:text-black dark:hover:text-white transition-all duration-200 cursor-pointer">Copy</button>
          </div>
          <div id="json-status" class="text-xs font-mono hidden"></div>
          <textarea id="json-output" rows="6" readonly placeholder="Output appears here..." class="w-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white px-3 py-2 text-sm font-mono focus:outline-none resize-none"></textarea>
        </div>
      </div>

    </div>
  </div>

  <script is:inline>
    // ── Book Details Retriever (ISBN) ─────────────────────────────
    function validateISBN(raw) {
      const cleaned = raw.replace(/[\s\-]/g, '');
      if (cleaned.length === 10) {
        if (!/^[0-9]{9}[0-9X]$/.test(cleaned)) return null;
        let sum = 0;
        for (let i = 0; i < 9; i++) sum += (10 - i) * parseInt(cleaned[i]);
        const check = cleaned[9] === 'X' ? 10 : parseInt(cleaned[9]);
        sum += check;
        return sum % 11 === 0 ? cleaned : null;
      }
      if (cleaned.length === 13) {
        if (!/^97[89][0-9]{10}$/.test(cleaned)) return null;
        let sum = 0;
        for (let i = 0; i < 12; i++) sum += parseInt(cleaned[i]) * (i % 2 === 0 ? 1 : 3);
        const check = (10 - (sum % 10)) % 10;
        return parseInt(cleaned[12]) === check ? cleaned : null;
      }
      return null;
    }

    document.getElementById('isbn-fetch').addEventListener('click', async () => {
      const raw = document.getElementById('isbn-input').value.trim();
      const errEl = document.getElementById('isbn-error');
      const loadEl = document.getElementById('isbn-loading');
      const resultEl = document.getElementById('isbn-result');

      errEl.classList.add('hidden');
      resultEl.classList.add('hidden');

      const isbn = validateISBN(raw);
      if (!isbn) {
        errEl.textContent = raw.length === 0
          ? '✗ Please enter an ISBN number.'
          : `✗ "${raw}" is not a valid ISBN-10 or ISBN-13 (check digit mismatch or wrong format).`;
        errEl.classList.remove('hidden');
        return;
      }

      loadEl.classList.remove('hidden');
      try {
        const url = `https://openlibrary.org/api/books?bibkeys=ISBN:${isbn}&format=json&jscmd=data`;
        const resp = await fetch(url);
        const data = await resp.json();
        const book = data[`ISBN:${isbn}`];

        if (!book) {
          loadEl.classList.add('hidden');
          errEl.textContent = `✗ No book found for ISBN ${isbn}. Try the other format (ISBN-10 vs ISBN-13).`;
          errEl.classList.remove('hidden');
          return;
        }

        const title    = book.title || 'Unknown Title';
        const author   = book.authors ? book.authors.map(a => a.name).join(', ') : 'Unknown Author';
        const coverUrl = book.cover?.large || book.cover?.medium || `https://covers.openlibrary.org/b/isbn/${isbn}-L.jpg`;
        const bookUrl  = `https://openlibrary.org/isbn/${isbn}`;
        const today    = new Date().toISOString().split('T')[0];
        const rawGenres = book.subjects ? book.subjects.slice(0, 4).map(s => s.name || s) : [];
        const genres   = rawGenres.length > 0 ? rawGenres : ['Non-fiction'];
        const genreList = genres.map(g => `"${g}"`).join(', ');
        const markdown = `---\ntitle: "${title}"\nauthor: "${author}"\ncoverImage: "${coverUrl}"\nurl: "${bookUrl}"\ndateAdded: ${today}\ngenres: [${genreList}]\n---`;

        document.getElementById('isbn-book-title').textContent  = title;
        document.getElementById('isbn-book-author').textContent = author;
        document.getElementById('isbn-book-genres').textContent = genres.join(' · ');
        document.getElementById('isbn-cover').src = coverUrl;
        document.getElementById('isbn-output').value = markdown;

        loadEl.classList.add('hidden');
        resultEl.classList.remove('hidden');
      } catch (err) {
        loadEl.classList.add('hidden');
        errEl.textContent = '✗ Network error. Please check your connection and try again.';
        errEl.classList.remove('hidden');
      }
    });

    document.getElementById('isbn-input').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('isbn-fetch').click();
    });

    document.getElementById('isbn-copy').addEventListener('click', () => {
      const out = document.getElementById('isbn-output').value;
      if (!out) return;
      navigator.clipboard.writeText(out).then(() => {
        const s = document.getElementById('isbn-copy-status');
        s.classList.remove('hidden');
        setTimeout(() => s.classList.add('hidden'), 2000);
      });
    });

    // ── RICE Score ──────────────────────────────────────────────
    document.getElementById('rice-calc').addEventListener('click', () => {
      const reach  = parseFloat(document.getElementById('rice-reach').value) || 0;
      const impact = parseFloat(document.getElementById('rice-impact').value) || 0;
      const conf   = parseFloat(document.getElementById('rice-confidence').value) || 0;
      const effort = parseFloat(document.getElementById('rice-effort').value) || 1;
      if (!reach || !conf || !effort) return;
      const score = (reach * impact * (conf / 100)) / effort;
      document.getElementById('rice-score').textContent = score.toFixed(1);
      document.getElementById('rice-result').classList.remove('hidden');
    });

    // ── Meeting Cost ─────────────────────────────────────────────
    document.getElementById('meet-calc').addEventListener('click', () => {
      const attendees = parseFloat(document.getElementById('meet-attendees').value) || 0;
      const salaryLPA = parseFloat(document.getElementById('meet-salary').value) || 0;
      const duration  = parseFloat(document.getElementById('meet-duration').value) || 0;
      const freq      = parseFloat(document.getElementById('meet-freq').value) || 0;
      if (!attendees || !salaryLPA || !duration || !freq) return;
      const hourly     = (salaryLPA * 100000) / (250 * 8);
      const perMeeting = hourly * (duration / 60) * attendees;
      const perMonth   = perMeeting * freq * 4;
      const perYear    = perMeeting * freq * 52;
      const fmt = (n) => '₹' + Math.round(n).toLocaleString('en-IN');
      document.getElementById('meet-per').textContent   = fmt(perMeeting);
      document.getElementById('meet-month').textContent = fmt(perMonth);
      document.getElementById('meet-year').textContent  = fmt(perYear);
      document.getElementById('meet-result').classList.remove('hidden');
    });

    // ── Reading Time ──────────────────────────────────────────────
    document.getElementById('read-text').addEventListener('input', (e) => {
      const text  = e.target.value.trim();
      const words = text ? text.split(/\s+/).length : 0;
      const chars = text.length;
      const mins  = Math.ceil(words / 238);
      document.getElementById('read-words').textContent = words.toLocaleString();
      document.getElementById('read-chars').textContent = chars.toLocaleString();
      document.getElementById('read-time').textContent  = words < 5 ? '0m' : `${mins}m`;
    });

    // ── JSON Formatter ────────────────────────────────────────────
    const jsonInput  = document.getElementById('json-input');
    const jsonOutput = document.getElementById('json-output');
    const jsonStatus = document.getElementById('json-status');

    function setStatus(msg, ok) {
      jsonStatus.textContent = msg;
      jsonStatus.className = `text-xs font-mono ${ok ? 'text-green-600 dark:text-green-400' : 'text-red-500'}`;
      jsonStatus.classList.remove('hidden');
    }

    document.getElementById('json-format').addEventListener('click', () => {
      try {
        const parsed = JSON.parse(jsonInput.value);
        jsonOutput.value = JSON.stringify(parsed, null, 2);
        setStatus('✓ Valid JSON', true);
      } catch (e) {
        jsonOutput.value = '';
        setStatus('✗ ' + e.message, false);
      }
    });

    document.getElementById('json-minify').addEventListener('click', () => {
      try {
        const parsed = JSON.parse(jsonInput.value || jsonOutput.value);
        jsonOutput.value = JSON.stringify(parsed);
        setStatus('✓ Minified', true);
      } catch (e) {
        setStatus('✗ ' + e.message, false);
      }
    });

    document.getElementById('json-copy').addEventListener('click', () => {
      const text = jsonOutput.value;
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        setStatus('✓ Copied to clipboard!', true);
        setTimeout(() => jsonStatus.classList.add('hidden'), 2000);
      });
    });
  </script>
</BaseLayout>
