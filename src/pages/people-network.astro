---
import BaseLayout from '../layouts/BaseLayout.astro';
import NetworkGraph from '../components/NetworkGraph.astro';
---

<BaseLayout title="My Network | Portfolio" description="A structured view of my professional and personal network.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    
    <div class="mb-12 border-b-2 border-black dark:border-white pb-6">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-brand-gray-900 dark:text-white leading-tight mb-4 uppercase">
        Network<span class="text-gray-400">.</span>
      </h1>
      <p class="text-lg md:text-xl text-brand-gray-600 dark:text-gray-300 font-medium">
        A structured, interactive view of the people behind the projects. Hover for info, click to pin profiles.
      </p>
    </div>

    <div class="border-2 border-black dark:border-white mb-8">
      <NetworkGraph />
    </div>
    

  </div>
</BaseLayout>
