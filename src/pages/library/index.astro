---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allLibrary = await getCollection('library');
allLibrary.sort((a, b) => a.data.title.localeCompare(b.data.title));

const groupedLibrary = allLibrary.reduce((acc, book) => {
  const genres = book.data.genres && book.data.genres.length > 0 ? book.data.genres : ['Uncategorized'];
  genres.forEach((genre: string) => {
    if (!acc[genre]) acc[genre] = [];
    acc[genre].push(book);
  });
  return acc;
}, {} as Record<string, typeof allLibrary>);

const genresList = Object.keys(groupedLibrary).sort();
---

<BaseLayout title="Library - Deepraj R" description="A collection of books I'm reading or have previously read.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <div class="mb-20 pb-12 border-b-2 border-black dark:border-white">
      <a href="/hobbies" class="text-xs font-black tracking-widest uppercase text-black dark:text-white opacity-40 hover:opacity-100 mb-12 inline-block transition-all underline underline-offset-4 decoration-2">&larr; Back to Hobbies</a>
      <h1 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 text-black dark:text-white uppercase">
        Library
      </h1>
      <p class="text-lg text-black dark:text-white font-bold opacity-70 max-w-2xl leading-relaxed">
        A running repository of books I'm reading, recommended reads, and structural works that shape my operational thinking.
      </p>
    </div>

    <div class="space-y-32">
      {genresList.map(genre => (
        <section>
          <div class="mb-12 flex items-center gap-6">
            <h2 class="text-2xl font-black tracking-widest uppercase text-black dark:text-white">{genre}</h2>
            <div class="h-1 bg-black dark:bg-white flex-grow opacity-20"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-x-8 gap-y-16">
            {groupedLibrary[genre].map((book) => (
              <a href={book.data.url || '#'} target="_blank" rel="noopener noreferrer" class="block group">
                <div class="aspect-[2/3] bg-white dark:bg-black overflow-hidden mb-6 border-2 border-black dark:border-white shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] group-hover:shadow-[10px_10px_0px_0px_rgba(0,0,0,1)] dark:group-hover:shadow-[10px_10px_0px_0px_rgba(255,255,255,1)] transition-all duration-300">
                  {book.data.coverImage ? (
                    <img src={book.data.coverImage} alt={book.data.title} class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex flex-col items-center justify-center p-6 text-center">
                      <span class="text-[10px] font-black uppercase text-black dark:text-white tracking-widest opacity-40">{book.data.title}</span>
                    </div>
                  )}
                </div>
                <h3 class="text-sm font-black text-black dark:text-white uppercase tracking-tight line-clamp-2 leading-none mb-2">{book.data.title}</h3>
                <p class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white opacity-40 line-clamp-1">{book.data.author}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
