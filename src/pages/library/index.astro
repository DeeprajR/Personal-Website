---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allLibrary = await getCollection('library');
allLibrary.sort((a, b) => a.data.title.localeCompare(b.data.title));

const groupedLibrary = allLibrary.reduce((acc, book) => {
  const genres = book.data.genres && book.data.genres.length > 0 ? book.data.genres : ['Uncategorized'];
  genres.forEach((genre: string) => {
    if (!acc[genre]) acc[genre] = [];
    acc[genre].push(book);
  });
  return acc;
}, {} as Record<string, typeof allLibrary>);

const genresList = Object.keys(groupedLibrary).sort();
---

<BaseLayout title="Library - Deepraj R" description="A collection of books I'm reading or have previously read.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <div class="mb-16">
      <a href="/hobbies" class="text-sm font-bold tracking-widest uppercase text-gray-400 hover:text-black dark:text-gray-500 dark:hover:text-white mb-12 inline-block transition-colors">&larr; Back to Hobbies</a>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-gray-900 dark:text-gray-100">
        Library
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl leading-relaxed">
        A running repository of books I'm reading, recommended reads, and structural works that shape my operational thinking.
      </p>
    </div>

    <div class="space-y-24">
      {genresList.map(genre => (
        <section>
          <div class="mb-8 flex items-center gap-4">
            <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100">{genre}</h2>
            <div class="h-px bg-gray-200 dark:bg-gray-800 flex-grow mt-2"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-x-6 gap-y-12">
            {groupedLibrary[genre].map((book) => (
              <a href={book.data.url || '#'} target="_blank" rel="noopener noreferrer" class="block group">
                <div class="aspect-[2/3] bg-gray-100 dark:bg-gray-800 overflow-hidden mb-4 border border-gray-100 dark:border-gray-800 shadow-sm group-hover:shadow-md transition-all duration-300">
                  {book.data.coverImage ? (
                    <img src={book.data.coverImage} alt={book.data.title} class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex flex-col items-center justify-center p-4 text-center">
                      <span class="text-xs font-bold font-mono text-gray-400 dark:text-gray-500">{book.data.title}</span>
                    </div>
                  )}
                </div>
                <h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white transition-colors line-clamp-2 leading-tight mb-1">{book.data.title}</h3>
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 line-clamp-1">{book.data.author}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
