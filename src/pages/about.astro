---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: "AI Product Manager",
    company: "Foodo AI",
    period: "Jan 2026 - Present",
    url: "https://foodo.ai",
    description: "Currently leading product strategy and roadmap execution across 3 distinct AI-driven products tailored specifically for the Restaurant Technology industry. Fully focused on delivering scalable machine learning implementations that solve complex operational problems.",
  },
  {
    role: "Associate Account Manager",
    company: "Wattlecorp Cybersecurity Labs",
    period: "Mar 2025 - Oct 2025",
    url: "https://wattlecorp.com",
    description: "Managed enterprise client relationships, ensuring seamless delivery of cutting-edge cybersecurity audits, vulnerability remediation, and architecture consulting.",
  },
  {
    role: "Marketing Executive",
    company: "Beagle Security",
    period: "Apr 2022 - Mar 2023",
    url: "https://beaglesecurity.com",
    description: "Spearheaded growth marketing initiatives. Analyzed market trends to optimize product messaging, dramatically improving user acquisition and conversion funnels.",
  },
  {
    role: "Content Writing Intern",
    company: "Beagle Security",
    period: "Nov 2021 - Apr 2022",
    url: "https://beaglesecurity.com",
    description: "Produced technical and marketing content centered on application security. Translated deeply technical vulnerability contexts into approachable product documentation.",
  }
];
---

<BaseLayout title="About | Deepraj R" description="My journey, operating principles, and professional experience.">
  
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <!-- Header -->
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-6 text-black dark:text-white uppercase">
        Hello. I'm Deepraj. <span class="seasonal-emoji">👋</span>
      </h1>
      <p class="seasonal-greeting hidden text-xs font-black uppercase tracking-widest text-black dark:text-white mb-8"></p>
      <p class="text-xl text-black dark:text-white leading-relaxed font-bold max-w-3xl">
        I'm a Product Manager who sits squarely at the messy intersection of engineering logic, beautiful design, and human psychology.
      </p>
    </div>

    <!-- Narrative -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 mb-24 border-b-2 border-black dark:border-white pb-24 mt-16">
      <div class="md:col-span-4">
        <h2 class="text-2xl font-black tracking-tighter text-black dark:text-white mb-4 uppercase">The Backstory</h2>
      </div>
      <div class="md:col-span-8 prose prose-lg text-black dark:text-white font-bold opacity-100">
        <p class="mb-6 leading-relaxed">
          My journey started in marketing technology and content, deeply immersed in learning how to communicate complex technical value in the rigorous space of application security. Over time, my fascination naturally evolved from simply marketing products into actively shaping how they are built and structured.
        </p>
        <p class="leading-relaxed">
          Today, I operate at the intersection of developers, growth, operations teams, and stakeholders. I specialize in untangling sophisticated user problems, architecting product roadmaps, and leading cross-functional teams to deliver solutions that are not only secure and scalable, but structurally intuitive for human beings to use.
        </p>
      </div>
    </div>

    <!-- Photos Montage -->
    <div class="relative mb-32">
      <div class="grid grid-cols-2 gap-8 relative">
        <div class="border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] rotate-[-1deg] hover:rotate-0 transition-all duration-500 overflow-hidden bg-white dark:bg-black">
          <img src="/images/Deepraj-in-tech-seminar.webp?auto=format&fit=crop&w=800&q=80" alt="Working out a problem" class="w-full h-80 md:h-[500px] object-cover grayscale hover:grayscale-0 transition-all duration-700" />
        </div>
        <div class="border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] rotate-[1deg] hover:rotate-0 transition-all duration-500 mt-12 md:mt-24 overflow-hidden bg-white dark:bg-black">
          <img src="/images/deepraj-presentation.webp?auto=format&fit=crop&w=800&q=80" alt="Presenting team about cybersecurity attacks" class="w-full h-80 md:h-[500px] object-cover grayscale hover:grayscale-0 transition-all duration-700" />
        </div>
      </div>
    </div>

    <!-- Experience Timeline -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 mb-32">
      <div class="md:col-span-4">
        <h2 class="text-2xl font-black tracking-tighter text-black dark:text-white mb-4 uppercase">Career Timeline</h2>
      </div>
      <div class="md:col-span-8">
        <ul class="space-y-0">
          {experience.map((job) => (
            <li class="relative pl-10 md:pl-16 pb-16 last:pb-0 border-l-2 border-black dark:border-white last:border-transparent">
              <div class="absolute -left-[9px] top-2 w-4 h-4 border-2 border-black dark:border-white bg-black dark:bg-white transition-all"></div>
              
              <h3 class="text-2xl font-black text-black dark:text-white uppercase tracking-tighter leading-none mb-4">{job.role}</h3>
              <div class="flex flex-wrap items-center gap-4 text-xs font-black tracking-widest uppercase mb-6">
                <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-black dark:text-white underline underline-offset-4 decoration-2 transition-all">
                  {job.company}
                </a>
                <span class="text-black dark:text-white">/</span>
                <span class="text-black dark:text-white uppercase tracking-widest">{job.period}</span>
              </div>
              <p class="text-lg text-black dark:text-white font-bold leading-relaxed max-w-2xl">
                {job.description}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Why connect block -->
    <div class="bg-white dark:bg-black p-10 md:p-16 border-2 border-black dark:border-white shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] dark:shadow-[12px_12px_0px_0px_rgba(255,255,255,1)] mb-24">
      <h3 class="text-2xl font-black text-black dark:text-white mb-12 uppercase tracking-tighter leading-none">Let's work together</h3>
      <ul class="space-y-10">
        <li class="flex items-start gap-6">
          <div class="w-8 h-8 flex items-center justify-center border-2 border-black dark:border-white shrink-0 bg-black dark:bg-white text-white dark:text-black">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
          </div>
          <span class="text-lg text-black dark:text-white font-bold leading-relaxed"><strong class="font-black uppercase tracking-tight mr-2">Grab a coffee:</strong> I love chatting about hardware, edge computing, design systems, or obscure technical lore anywhere in the world.</span>
        </li>
        <li class="flex items-start gap-6">
          <div class="w-8 h-8 flex items-center justify-center border-2 border-black dark:border-white shrink-0 bg-black dark:bg-white text-white dark:text-black">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <span class="text-lg text-black dark:text-white font-bold leading-relaxed"><strong class="font-black uppercase tracking-tight mr-2">Collaborate:</strong> Always open to mentoring, bouncing ideas around for startup founders, or auditing complex product funnels.</span>
        </li>
        <li class="flex items-start gap-6">
          <div class="w-8 h-8 flex items-center justify-center border-2 border-black dark:border-white shrink-0 bg-emerald-500 text-white dark:text-black">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          </div>
          <span class="text-lg text-black dark:text-white font-bold leading-relaxed">
            <span class="font-black text-black dark:text-white underline decoration-4 underline-offset-4 tracking-tighter uppercase mr-2">Currently open to new roles.</span> If your team needs someone who can naturally bridge the gap between creative chaos and analytical spreadsheets, we should absolutely talk.
          </span>
        </li>
      </ul>
    </div>
    
    <!-- CTA -->
    <div class="flex flex-wrap gap-6 items-center mb-12">
      <a href="mailto:hello@deeprajr.com" class="inline-flex justify-center items-center px-10 py-5 border-2 border-black dark:border-white text-xs font-black tracking-widest uppercase rounded-none text-white dark:text-black bg-black dark:bg-white hover:bg-white dark:hover:bg-black hover:text-black dark:hover:text-white transition-all shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] active:shadow-none translate-y-[-2px]">
        Get In Touch &rarr;
      </a>
      <a href="https://www.linkedin.com/in/deeprajr/" target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center px-10 py-5 border-2 border-black dark:border-white text-xs font-black tracking-widest uppercase rounded-none text-black dark:text-white bg-transparent hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black transition-all shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] active:shadow-none translate-y-[-2px]">
        Connect on LinkedIn
      </a>
    </div>

  </div>
</BaseLayout>
