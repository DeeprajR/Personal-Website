      <img src="/logos/eci-logo.svg" alt="ECI" width="144" height="48" class="h-10 w-28 md:h-12 md:w-36 object-contain shrink-0 opacity-50 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 grayscale hover:grayscale-0 transition-all duration-300" />
      <img src="/logos/foodo.svg" alt="Foodo" width="144" height="48" class="h-10 w-28 md:h-12 md:w-36 object-contain shrink-0 opacity-50 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 grayscale hover:grayscale-0 transition-all duration-300" />
      <img src="/logos/kerala-police-logo-dark.webp" alt="Kerala Police" width="144" height="48" class="h-10 w-28 md:h-12 md:w-36 object-contain shrink-0 opacity-50 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 grayscale hover:grayscale-0 transition-all duration-300" />
      <img src="/logos/mulearn.webp" alt="mulearn" width="144" height="48" class="h-10 w-28 md:h-12 md:w-36 object-contain shrink-0 opacity-50 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 grayscale hover:grayscale-0 transition-all duration-300" />
      <img src="/logos/tinkerhub_logo.webp" alt="TinkerHub" width="144" height="48" class="h-10 w-28 md:h-12 md:w-36 object-contain shrink-0 opacity-50 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 grayscale hover:grayscale-0 mix-blend-multiply dark:mix-blend-normal transition-all duration-300" />
      <img src="/logos/uproot-security-dark.svg" alt="Uproot Security" width="144" height="48" class="h-10 w-28 md:h-12 md:w-36 object-contain shrink-0 opacity-50 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 grayscale hover:grayscale-0 transition-all duration-300" />
      <img src="/logos/360_marketing_school.webp" alt="360 Marketing School" width="144" height="48" class="h-10 w-28 md:h-12 md:w-36 object-contain shrink-0 opacity-50 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 grayscale hover:grayscale-0 mix-blend-multiply dark:mix-blend-normal transition-all duration-300" />
    </div>
