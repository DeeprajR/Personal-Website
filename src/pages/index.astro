  <!-- Selected Work -->
  <section id="work" class="max-w-5xl mx-auto px-6 py-24 border-b border-gray-100 dark:border-gray-800">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-black tracking-tight text-black dark:text-white mb-4 uppercase">Signature Projects</h2>
        <p class="text-black dark:text-white font-bold max-w-xl">Deep-dive case studies on deploying high-leverage systems to align engineering, product, and business goals.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {topWork.map((entry) => (
        <a href={`/work/${entry.id}`} class="group block border-2 border-black dark:border-white p-8 bg-white dark:bg-black text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-300 flex flex-col h-full overflow-hidden relative">
          <h3 class="text-xl font-black mb-3 uppercase tracking-tight group-hover:text-white dark:group-hover:text-black transition-colors">{entry.data.title}</h3>
          
          <div class="mb-6 flex-grow">
            <p class="text-sm font-bold line-clamp-3 leading-relaxed group-hover:opacity-100 group-hover:text-white dark:group-hover:text-black transition-colors">{entry.data.description}</p>
          </div>
          
          <div class="mt-auto pt-6 border-t border-black dark:border-white group-hover:border-white dark:group-hover:border-black flex items-center justify-between text-xs font-black uppercase tracking-widest transition-colors">
            <span class="group-hover:text-white dark:group-hover:text-black">Outcome Insight &rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 flex justify-start">
      <a href="/work" class="inline-flex justify-center items-center px-6 py-3 border-2 border-black dark:border-white text-sm font-bold tracking-widest uppercase rounded-none text-black dark:text-white bg-transparent hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black transition-colors">
        Browse All Work &rarr;
      </a>
    </div>
  </section>

  <!-- Brief About Section -->
  <section id="about" class="max-w-7xl mx-auto px-6 py-24 md:py-32 border-b border-gray-100 dark:border-gray-800 overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-center">
      
      <div class="md:col-span-5 relative">
        <Image src={speakerImg} alt="Deepraj R" class="rounded-3xl w-full h-[350px] md:h-[450px] object-cover shadow-sm transition-transform duration-700 hover:scale-[1.02]" />
        <div class="seasonal-aura absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-gradient-to-tr from-gray-200 to-transparent dark:from-gray-800 dark:to-transparent rounded-full blur-[80px] opacity-60 transition-colors duration-[2000ms]"></div>
      </div>

      <div class="md:col-span-7 space-y-6">
        <h2 class="text-4xl lg:text-5xl font-black tracking-tight text-black dark:text-white mb-4 uppercase">
          Hi, I'm Deepraj. <span class="seasonal-emoji">👋</span>
        </h2>
        <p class="seasonal-greeting hidden text-xs font-black uppercase tracking-widest text-black dark:text-white mb-6"></p>
        <p class="text-xl text-black dark:text-white leading-relaxed font-bold">
          I'm a Product Manager who sits squarely at the messy intersection of engineering logic, beautiful design, and user psychology.
        </p>
        <p class="text-lg text-black dark:text-white leading-relaxed font-bold mb-8">
          My journey didn't start in a sterile boardroom. It started with tearing apart hardware and software and trying to figure out how complex systems were wired together. Over the years, I've evolved into untangling organizational friction and architecting products with empathy.
        </p>
        <div class="pt-4">
          <a href="/about" class="inline-flex justify-center items-center px-6 py-3 border-2 border-black dark:border-white text-sm font-bold tracking-widest uppercase rounded-none text-black dark:text-white bg-transparent hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black transition-colors">
            Read My Full Story &rarr;
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Currently Learning -->
  <section id="learning" class="max-w-5xl mx-auto px-6 py-24 border-b border-gray-100 dark:border-gray-800">
    <div class="mb-12">
      <h2 class="text-3xl font-black tracking-tight text-black dark:text-white mb-4 uppercase">Currently Learning</h2>
      <p class="text-black dark:text-white font-bold max-w-xl">What I'm actively studying right now — journal entries, notes, and frameworks.</p>
    </div>

    <div class="space-y-6">
      {activeTopics.map(topic => {
        const topicEntries = (entriesByTopic[topic.id] || []).slice(0, 3);
        return (
          <div class="group border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-300">
            <a href={`/learning/${topic.id}`} class="block p-8">
              <div class="flex items-center gap-4 mb-4">
                <div class="flex-grow">
                  <h3 class="text-xl font-black tracking-tight uppercase group-hover:text-white dark:group-hover:text-black transition-colors">{topic.name}</h3>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                  </span>
                  <span class="text-[10px] font-bold uppercase tracking-widest text-emerald-600 dark:text-emerald-400">Active</span>
                </div>
              </div>
            </a>
            {topicEntries.length > 0 && (
              <div class="border-t border-black dark:border-white group-hover:border-white dark:group-hover:border-black transition-colors">
                {topicEntries.map((entry, i) => {
                  const slug = entry.id.split('/').slice(1).join('/');
                  return (
                  <a href={`/learning/${topic.id}/${slug}`} class={`group/entry block px-8 py-4 flex items-baseline justify-between gap-4 text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black group-hover:text-white dark:group-hover:text-black transition-colors ${i < topicEntries.length - 1 ? 'border-b border-black dark:border-white group-hover:border-white dark:group-hover:border-black/20' : ''}`}>
                    <div class="flex items-baseline gap-4 min-w-0">
                      <span class="text-xs font-mono font-black shrink-0 w-20 group-hover:opacity-100 transition-opacity">
                        {entry.data.date.toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}
                      </span>
                      <span class="text-sm font-bold truncate transition-colors uppercase">
                        {entry.data.title}
                      </span>
                    </div>
                    <span class="text-xs font-black transition-colors">&rarr;</span>
                  </a>
