---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import heroImg from '../assets/deepraj-black-and-white.webp';
import speakerImg from '../assets/deepraj-speaker.webp';
import { learningTopics } from '../data/learningTopics';

const workEntries = await getCollection('work');
const learningEntries = await getCollection('learning');
const photographyEntries = await getCollection('photography');

// Sort by date (descending)
workEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
learningEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
photographyEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get top entries
const topWork = workEntries.slice(0, 4);

// Group learning entries by topic
function getTopicId(entryId: string): string {
  const parts = entryId.split('/');
  return parts.length > 1 ? parts[0] : 'uncategorized';
}
const entriesByTopic = learningEntries.reduce((acc, entry) => {
  const topicId = getTopicId(entry.id);
  if (!acc[topicId]) acc[topicId] = [];
  acc[topicId].push(entry);
  return acc;
}, {} as Record<string, typeof learningEntries>);

const activeTopics = learningTopics.filter(t => t.status === 'active');
---

<BaseLayout title="Deepraj R | Product Manager">
  
  <!-- Hero Section -->
  <section class="max-w-5xl mx-auto px-6 py-24 md:py-32 flex flex-col md:flex-row md:items-center gap-12 md:gap-16">
    <div class="max-w-2xl flex-1">
      <h1 class="text-4xl md:text-6xl font-black tracking-tight text-black dark:text-white leading-tight mb-6 animate-fade-in-up opacity-0">
        Helps you turn chaos into aligned execution.
      </h1>
      <p class="text-lg md:text-xl text-black dark:text-white mb-10 leading-relaxed font-bold">
        Product Manager guiding tech, marketing, and business teams to transform ambiguous problems into shipped outcomes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 relative z-20">
        <a href="#work" class="inline-flex justify-center items-center px-6 py-3 border-2 border-black dark:border-white text-sm font-bold tracking-widest uppercase rounded-none text-white dark:text-black bg-black dark:bg-white hover:bg-transparent dark:hover:bg-transparent hover:text-black dark:hover:text-white transition-colors">
          See Outcomes
        </a>
        <a href="/learning" class="inline-flex justify-center items-center px-6 py-3 border-2 border-black dark:border-white text-sm font-bold tracking-widest uppercase rounded-none text-black dark:text-white bg-transparent hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black transition-colors">
          Learning Journal
        </a>
      </div>
    </div>
    <div class="hidden md:block w-48 h-48 lg:w-64 lg:h-64 shrink-0 relative group">
      <div class="absolute inset-0 bg-gray-200 rounded-full animate-pulse group-hover:hidden"></div>
      <Image src={heroImg} alt="Deepraj R" class="relative z-10 w-full h-full object-cover rounded-full shadow-sm grayscale hover:grayscale-0 transition-all duration-500" loading="eager" />
    </div>
  </section>

  <!-- Credibility / Proof Strip -->
  <section class="border-y border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50 py-12">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <p class="text-sm font-black tracking-widest uppercase text-black dark:text-white mb-4">
        Product | Technology | Marketing | Research
      </p>
      <p class="text-lg font-bold text-black dark:text-white max-w-2xl mx-auto">
        Proven track record of coordinating cross-functional teams and delivering complex initiatives.
      </p>
    </div>
  </section>

  <!-- Endless Logo Runner -->
  <!-- Endless Logo Runner -->
