---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { learningTopics } from '../../data/learningTopics';

const allLearning = await getCollection('learning');

// Derive topic from the entry ID path (e.g., "mckinsey-forward/debiasing" → "mckinsey-forward")
function getTopicId(entryId: string): string {
  const parts = entryId.split('/');
  return parts.length > 1 ? parts[0] : 'uncategorized';
}

// Group entries by topic
const entriesByTopic = allLearning.reduce((acc, entry) => {
  const topicId = getTopicId(entry.id);
  if (!acc[topicId]) acc[topicId] = [];
  acc[topicId].push(entry);
  return acc;
}, {} as Record<string, typeof allLearning>);

// Sort entries within each topic by date (newest first)
Object.values(entriesByTopic).forEach(entries => {
  entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
});

const activeTopics = learningTopics.filter(t => t.status === 'active');
const plannedTopics = learningTopics.filter(t => t.status === 'planned');
const completedTopics = learningTopics.filter(t => t.status === 'completed');
---

<BaseLayout title="Learning Journal | Deepraj R" description="A journal of everything I'm currently learning and plan to learn next.">
  <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">

    <!-- Header -->
    <header class="mb-20 border-b-2 border-black dark:border-white pb-12">
      <h1 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 text-black dark:text-white uppercase">
        Learning Journal
      </h1>
      <p class="text-xl text-black dark:text-white font-bold max-w-2xl leading-relaxed">
        Documenting what I'm learning — one entry at a time. Notes, frameworks, and insights organized by topic.
      </p>
    </header>

    <!-- Active Topics -->
    <section class="mb-24">
      <div class="mb-10 flex items-center gap-6">
        <h2 class="text-2xl font-black tracking-tighter text-black dark:text-white uppercase">Currently Learning</h2>
        <div class="h-1 bg-black dark:bg-white flex-grow"></div>
      </div>

      <div class="grid grid-cols-1 gap-10">
        {activeTopics.map(topic => {
          const entries = entriesByTopic[topic.id] || [];
          const latestDate = entries.length > 0 ? entries[0].data.date : null;
          return (
            <div class="group border-2 border-black dark:border-white transition-all duration-300 bg-white dark:bg-black text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] dark:hover:shadow-[12px_12px_0px_0px_rgba(255,255,255,1)]">
              <a href={`/learning/${topic.id}`} class="block p-8 transition-all">
                <div class="flex items-start justify-between gap-6 mb-6">
                  <div>
                    <h3 class="text-2xl font-black tracking-tighter uppercase mb-2">
                      {topic.name}
                    </h3>
                    <p class="text-sm font-bold">{topic.description}</p>
                  </div>
                  <div class="flex items-center gap-3 shrink-0 bg-emerald-500 text-white dark:text-black font-black uppercase text-[10px] tracking-widest px-3 py-1 border-2 border-black dark:border-white group-hover:border-white dark:group-hover:border-black transition-colors">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white dark:bg-black opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-white dark:bg-black"></span>
                    </span>
                    Active
                  </div>
                </div>

                <div class="flex items-center gap-6 text-xs font-black uppercase tracking-widest group-hover:opacity-100 transition-all">
                  <span>{entries.length} {entries.length === 1 ? 'entry' : 'entries'}</span>
                  {latestDate && (
                    <span>Last updated {latestDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  )}
                </div>
              </a>

              {/* Recent entries preview */}
              {entries.length > 0 && (
                <div class="border-t-2 border-black dark:border-white group-hover:border-white dark:group-hover:border-black transition-colors">
                  {entries.slice(0, 3).map((entry, i) => {
                    const slug = entry.id.split('/').slice(1).join('/');
                    return (
                    <a href={`/learning/${topic.id}/${slug}`} class={`block px-8 py-5 flex items-center justify-between gap-4 transition-all ${i < Math.min(entries.length, 3) - 1 ? 'border-b-2 border-black dark:border-white/20 group-hover:border-white dark:group-hover:border-black/20' : ''}`}>
                      <div class="flex items-center gap-6 min-w-0">
                        <span class="text-[10px] font-black shrink-0 w-24 group-hover:opacity-100 uppercase tracking-widest transition-colors">
                          {entry.data.date.toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}
                        </span>
                        <span class="text-sm font-black uppercase tracking-tight truncate">
                          {entry.data.title}
                        </span>
                      </div>
                      <span class="text-xs font-black leading-none">→</span>
                    </a>
                  )})}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <!-- Completed Topics -->
    {completedTopics.length > 0 && (
    <section class="mb-24">
      <div class="mb-10 flex items-center gap-6">
        <h2 class="text-2xl font-black tracking-tighter text-black dark:text-white uppercase">Completed</h2>
        <div class="h-1 bg-black dark:bg-white flex-grow"></div>
      </div>

      <div class="grid grid-cols-1 gap-10">
        {completedTopics.map(topic => {
          const entries = entriesByTopic[topic.id] || [];
          const latestDate = entries.length > 0 ? entries[0].data.date : null;
          return (
            <div class="group border-2 border-black dark:border-white bg-white dark:bg-black text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-300 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] hover:opacity-100 pl-0">
              <a href={`/learning/${topic.id}`} class="block p-8 transition-all">
                <div class="flex items-start justify-between gap-6 mb-6">
                  <div>
                    <h3 class="text-2xl font-black tracking-tighter uppercase mb-2 group-hover:text-white dark:group-hover:text-black transition-colors">
                      {topic.name}
                    </h3>
                    <p class="text-sm font-bold group-hover:text-white dark:group-hover:text-black transition-colors">{topic.description}</p>
                  </div>
                  <div class="flex items-center gap-3 shrink-0 bg-black dark:bg-white text-white dark:text-black font-black uppercase text-[10px] tracking-widest px-3 py-1 transition-colors border-2 border-white dark:border-black group-hover:bg-white group-hover:text-black dark:group-hover:bg-black dark:group-hover:text-white group-hover:border-black dark:group-hover:border-white">
                    Complete
                  </div>
                </div>

                <div class="flex items-center gap-6 text-xs font-black tracking-widest uppercase group-hover:opacity-100 group-hover:text-white dark:group-hover:text-black transition-all">
                  <span>{entries.length} {entries.length === 1 ? 'entry' : 'entries'}</span>
                  {latestDate && (
                    <span>Last updated {latestDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  )}
                </div>
              </a>
            </div>
          );
        })}
      </div>
    </section>
    )}

    <!-- Planned Topics -->
    <section>
      <div class="mb-10 flex items-center gap-6">
        <h2 class="text-2xl font-black tracking-tighter text-black dark:text-white uppercase">Up Next</h2>
        <div class="h-1 bg-black dark:bg-white flex-grow opacity-20"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {plannedTopics.map(topic => (
          <div class="border-2 border-black dark:border-white p-6 bg-white dark:bg-black hover:bg-black dark:hover:bg-white transition-all duration-300 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)] group">
            <div class="flex items-center justify-end mb-6">
              <span class="text-[10px] font-black uppercase tracking-widest text-black dark:text-white border-2 border-black dark:border-white px-2 py-0.5 group-hover:text-white dark:group-hover:text-black group-hover:border-white dark:group-hover:border-black transition-all">Coming Soon</span>
            </div>
            <h3 class="text-lg font-black text-black dark:text-white group-hover:text-white dark:group-hover:text-black tracking-tighter mb-3 uppercase leading-none">
              {topic.name}
            </h3>
            <p class="text-xs text-black dark:text-white group-hover:text-white dark:group-hover:text-black font-bold leading-relaxed line-clamp-3">
              {topic.description}
            </p>
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
