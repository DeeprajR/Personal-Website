---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import SeasonalEffects from '../components/SeasonalEffects.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Deepraj R - Product Manager" } = Astro.props;
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Deepraj R" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={`https://deeprajr.com${pathname}`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://deeprajr.com${pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Deepraj R - Product Manager" />
    <meta property="og:image" content="https://deeprajr.com/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`https://deeprajr.com${pathname}`} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://deeprajr.com/og-image.jpg" />
    <meta name="twitter:creator" content="@Deepraj_R_" />

    <!-- Generative Engine Optimization (GEO) & LLM Indexing -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Deepraj R",
        "url": "https://deeprajr.com",
        "jobTitle": "Product Manager",
        "description": "Product Manager guiding tech, marketing, and business teams to transform ambiguous problems into shipped outcomes.",
        "sameAs": [
          "https://www.linkedin.com/in/deeprajr/",
          "https://github.com/deeprajr",
          "https://x.com/Deepraj_R_"
        ]
      }
    </script>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
    
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      
      window.localStorage.setItem('theme', theme);
    </script>
    
    <!-- Google Analytics (Gtag) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-507Q7CMPSG" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      // Replace G-XXXXXXXXXX with your actual Google Analytics tracking ID
      gtag('config', 'G-507Q7CMPSG');
    </script>
  </head>
  <body class="bg-white dark:bg-black text-black dark:text-white min-h-screen flex flex-col font-sans antialiased selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black">

    <!-- Loading Screen -->
    <div id="page-loader" style="
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: opacity 0.6s ease, visibility 0.6s ease;
    ">
      <!-- Typewriter Container -->
      <div style="display: flex; align-items: center; gap: 0;">
        <span id="loader-text" style="
          font-family: 'Inter', sans-serif;
          font-size: clamp(1.1rem, 3vw, 1.6rem);
          font-weight: 700;
          letter-spacing: -0.03em;
          color: #000000;
        "></span>
        <span id="loader-cursor" style="
          display: inline-block;
          width: 2px;
          height: 1.5em;
          background: #111827;
          margin-left: 3px;
          vertical-align: middle;
          animation: blink 0.8s step-end infinite;
        "></span>
      </div>

      <!-- Progress Track -->
      <div style="
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: #000000;
        opacity: 0.1;
        overflow: hidden;
      ">
        <div id="loader-bar" style="
          height: 100%;
          width: 0%;
          background: #000000;
          transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        "></div>
      </div>
    </div>

    <style>
      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }
    </style>

    <script is:inline data-astro-rerun>
      (function() {
        const loader   = document.getElementById('page-loader');
        if (!loader) return;
        const textEl   = document.getElementById('loader-text');
        const cursor   = document.getElementById('loader-cursor');
        const bar      = document.getElementById('loader-bar');
        const isDark   = document.documentElement.classList.contains('dark');

        // Instantly apply dark mode colors before first paint
        if (isDark) {
          loader.style.background  = '#000000';
          textEl.style.color       = '#ffffff';
          cursor.style.background  = '#ffffff';
          bar.style.background     = '#ffffff';
        }

        const phrase  = 'Turning chaos into clarity.';
        const charMs  = 55; // ms between each character
        let   index   = 0;
        let   dismissed = false;

        // Start progress bar crawl immediately
        requestAnimationFrame(() => {
          setTimeout(() => { if (bar) bar.style.width = '65%'; }, 50);
        });

        // Typewriter tick
        function type() {
          if (index < phrase.length && !dismissed) {
            requestAnimationFrame(() => {
              if (textEl) textEl.textContent += phrase[index++];
              setTimeout(type, charMs);
            });
          }
        }
        setTimeout(type, 120); // slight delay before starting

        // Dismiss helper (idempotent)
        function dismiss() {
          if (dismissed) return;
          dismissed = true;
          if (bar) bar.style.width = '100%';
          setTimeout(() => {
            if (loader) {
              loader.style.opacity    = '0';
              loader.style.visibility = 'hidden';
              setTimeout(() => loader.remove(), 600);
            }
          }, 350);
        }

        // Dismiss on full page load or if already loaded
        if (document.readyState === 'complete') {
          setTimeout(dismiss, 100);
        } else {
          window.addEventListener('load', dismiss);
        }
        // Also handle Astro's soft navigation loaded state
        document.addEventListener('astro:page-load', dismiss, { once: true });

        // Safety fallback — never block user for more than 3.5s
        setTimeout(dismiss, 3500);
      })();
    </script>



    <header class="sticky top-0 z-50 bg-white/90 dark:bg-black/90 backdrop-blur-md border-b-2 border-black dark:border-white transition-colors duration-300">
      <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="font-bold text-lg tracking-tight dark:text-white relative z-50">Deepraj R</a>
        <div class="flex items-center gap-2 md:gap-6">
          <nav class="hidden md:flex gap-6 text-sm font-bold text-black dark:text-white items-center">
            <a href="/work" class="hover:underline transition-all">Work</a>
            <a href="/learning" class="hover:underline transition-all">Learning</a>
            <a href="/opportunity" class="hover:underline transition-all">Opportunity</a>
            <a href="/hobbies" class="hover:underline transition-all">Hobbies</a>
            <a href="/about" class="hover:underline transition-all">About</a>
            <!-- Tools dropdown -->
            <div class="relative group">
              <a href="/tools" class="hover:underline transition-all flex items-center gap-1">
                Tools
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </a>
              <div class="absolute left-0 top-full pt-2 w-72 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-200 z-[100]">
                <div class="bg-white dark:bg-black border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] py-4 px-6 flex flex-col gap-3">
                  <a href="/tools#book-retriever" class="text-xs font-black text-black dark:text-white hover:underline transition-all uppercase tracking-widest">Book Details Retriever</a>
                  <a href="/tools#markdown-table" class="text-xs font-black text-black dark:text-white hover:underline transition-all uppercase tracking-widest">Markdown Table Generator</a>
                  <a href="/tools#password-generator" class="text-xs font-black text-black dark:text-white hover:underline transition-all uppercase tracking-widest">Password Generator</a>
                  <a href="/tools#image-converter" class="text-xs font-black text-black dark:text-white hover:underline transition-all uppercase tracking-widest">Image Converter</a>
                </div>
              </div>
            </div>
            <a href="/#contact" class="hover:underline transition-all">Contact</a>
          </nav>
          
          {isHome ? (
            <div class="relative group inline-block" oncontextmenu="(e) => { e.preventDefault(); document.getElementById('season-dropdown').classList.toggle('hidden'); }">
            <button id="theme-toggle" type="button" class="text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black border-2 border-black dark:border-white focus:outline-none rounded-none text-sm p-2 transition-all cursor-pointer" aria-label="Toggle Dark Mode">
                <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
              </button>
              <div id="season-dropdown" class="absolute right-0 top-full mt-2 w-56 bg-white dark:bg-black border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-200 z-[100] p-3 flex flex-col gap-1 hidden group-hover:flex">
                <div class="text-[10px] font-black text-black dark:text-white uppercase tracking-widest px-3 py-2 border-b-2 border-black dark:border-white mb-1">Select Ritu (Weather)</div>
                <button class="season-selector flex items-center justify-start gap-4 w-full text-left px-3 py-2 text-sm font-bold hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all text-black dark:text-white uppercase tracking-tight" data-season="pause">⏸️ Pause</button>
                <button class="season-selector flex items-center justify-start gap-4 w-full text-left px-3 py-2 text-sm font-bold hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all text-black dark:text-white uppercase tracking-tight" data-season="winter">☕ Winter</button>
                <button class="season-selector flex items-center justify-start gap-4 w-full text-left px-3 py-2 text-sm font-bold hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all text-black dark:text-white uppercase tracking-tight" data-season="spring">🪁 Spring</button>
                <button class="season-selector flex items-center justify-start gap-4 w-full text-left px-3 py-2 text-sm font-bold hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all text-black dark:text-white uppercase tracking-tight" data-season="summer">🥭 Summer</button>
                <button class="season-selector flex items-center justify-start gap-4 w-full text-left px-3 py-2 text-sm font-bold hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all text-black dark:text-white uppercase tracking-tight" data-season="monsoon">🦚 Monsoon</button>
                <button class="season-selector flex items-center justify-start gap-4 w-full text-left px-3 py-2 text-sm font-bold hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all text-black dark:text-white uppercase tracking-tight" data-season="festive">🪔 Autumn</button>
              </div>
            </div>
          ) : (
            <button id="theme-toggle" type="button" class="text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black border-2 border-black dark:border-white focus:outline-none rounded-none text-sm p-2 transition-all cursor-pointer" aria-label="Toggle Dark Mode">
              <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
              <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
            </button>
          )}

          <!-- Mobile Menu Toggle -->
          <button id="mobile-menu-btn" class="md:hidden relative z-50 p-2 text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black border-2 border-black dark:border-white transition-all cursor-pointer" aria-label="Toggle Mobile Menu">
            <svg id="mobile-menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            <svg id="mobile-close-icon" class="hidden w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 top-16 bg-white dark:bg-black z-40 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col px-6 py-8 overflow-y-auto border-t-2 border-black dark:border-white">
      <nav class="flex flex-col gap-6 text-2xl font-black tracking-tighter text-black dark:text-white mt-4 uppercase">
          <a href="/work" class="mobile-nav-link hover:underline transition-colors">Work</a>
          <a href="/learning" class="mobile-nav-link hover:underline transition-colors">Learning</a>
          <a href="/opportunity" class="mobile-nav-link hover:underline transition-colors">Opportunity</a>
          <a href="/hobbies" class="mobile-nav-link hover:underline transition-colors">Hobbies</a>
          <a href="/about" class="mobile-nav-link hover:underline transition-colors">About</a>
          
          <div class="h-1 bg-black dark:bg-white my-4"></div>
          
          <a href="/tools" class="mobile-nav-link hover:underline transition-colors">Tools</a>
          <a href="/#contact" class="mobile-nav-link hover:underline transition-colors">Contact</a>
      </nav>
    </div>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="border-t-2 border-black dark:border-white mt-24 py-16 transition-colors duration-300 bg-white dark:bg-black text-black dark:text-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">

          <!-- Col 1: Brand -->
          <div class="col-span-2 md:col-span-1">
            <a href="/" class="font-black text-lg tracking-tight text-black dark:text-white">Deepraj R</a>
            <p class="text-sm text-black dark:text-white mt-2 leading-relaxed">
              Turning chaos into aligned execution.
            </p>
          </div>

          <!-- Col 2: Pages -->
          <div>
            <p class="text-xs font-black uppercase tracking-widest text-black dark:text-white mb-4">Pages</p>
            <ul class="space-y-2 text-sm font-bold text-black dark:text-white">
              <li><a href="/work"       class="hover:underline transition-all">Work</a></li>
              <li><a href="/learning"   class="hover:underline transition-all">Learning</a></li>
              <li><a href="/opportunity" class="hover:underline transition-all">Opportunity</a></li>
              <li><a href="/hobbies"    class="hover:underline transition-all">Hobbies</a></li>
              <li><a href="/about"      class="hover:underline transition-all">About</a></li>
              <li><a href="/#contact"   class="hover:underline transition-all">Contact</a></li>
            </ul>
          </div>

          <!-- Col 3: Tools -->
          <div class="col-span-1">
            <p class="text-xs font-black uppercase tracking-widest text-black dark:text-white mb-4">Tools</p>
            <ul class="space-y-2 text-sm font-bold text-black dark:text-white">
              <li><a href="/tools#book-retriever" class="hover:underline transition-all">Book Details Retriever</a></li>
              <li><a href="/tools#markdown-table" class="hover:underline transition-all">Markdown Table Generator</a></li>
              <li><a href="/tools#password-generator" class="hover:underline transition-all">Password Generator</a></li>
              <li><a href="/tools#image-converter" class="hover:underline transition-all">Image Converter</a></li>
            </ul>
          </div>

          <!-- Col 4: Social -->
          <div>
            <p class="text-xs font-black uppercase tracking-widest text-black dark:text-white mb-4">Elsewhere</p>
            <ul class="space-y-2 text-sm font-bold text-black dark:text-white">
              <li><a href="https://www.linkedin.com/in/deeprajr/" target="_blank" rel="noopener noreferrer" class="hover:underline transition-all">LinkedIn</a></li>
              <li><a href="https://github.com/deeprajr"           target="_blank" rel="noopener noreferrer" class="hover:underline transition-all">GitHub</a></li>
              <li><a href="https://x.com/Deepraj_R_"             target="_blank" rel="noopener noreferrer" class="hover:underline transition-all">X (Twitter)</a></li>
            </ul>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="border-t-2 border-black dark:border-white pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-black dark:text-white font-black uppercase tracking-[0.2em]">
          <p>&copy; {new Date().getFullYear()} Deepraj R. All rights reserved.</p>
          <div class="flex gap-4 font-black">
            <a href="/sitemap-index.xml" class="hover:underline transition-all">Sitemap</a>
            <a href="/humans.txt"        class="hover:underline transition-all">Humans.txt</a>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      function initThemeToggle() {
        const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
        const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
        const themeToggleBtn = document.getElementById('theme-toggle');

        if (!themeToggleBtn) return;

        // Change the icons inside the button based on previous settings
        if (document.documentElement.classList.contains('dark')) {
            themeToggleLightIcon?.classList.remove('hidden');
        } else {
            themeToggleDarkIcon?.classList.remove('hidden');
        }

        // Cleanup any previous event listeners to avoid duplicates on SPA nav
        const newBtn = themeToggleBtn.cloneNode(true);
        themeToggleBtn.parentNode.replaceChild(newBtn, themeToggleBtn);

        newBtn.addEventListener('click', function() {
            const darkIcon = document.getElementById('theme-toggle-dark-icon');
            const lightIcon = document.getElementById('theme-toggle-light-icon');
            // toggle icons inside button
            darkIcon?.classList.toggle('hidden');
            lightIcon?.classList.toggle('hidden');

            // if set via local storage previously
            if (localStorage.getItem('theme')) {
                if (localStorage.getItem('theme') === 'light') {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                }
            } else {
                // if NOT set via local storage previously
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                }
            }
        });
      }

      document.addEventListener('astro:page-load', () => {
        initThemeToggle();
        initMobileMenu();
      });

      function initMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        if (!btn || !menu) return;

        // Replace btn to clear old listeners from SPA nav
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);

        const iconMenu = document.getElementById('mobile-menu-icon');
        const iconClose = document.getElementById('mobile-close-icon');
        const links = document.querySelectorAll('.mobile-nav-link');
        let isOpen = false;

        function toggleMenu() {
          isOpen = !isOpen;
          if (isOpen) {
            menu.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';
            iconMenu?.classList.add('hidden');
            iconClose?.classList.remove('hidden');
          } else {
            menu.classList.add('translate-x-full');
            document.body.style.overflow = '';
            iconClose?.classList.add('hidden');
            iconMenu?.classList.remove('hidden');
          }
        }

        newBtn.addEventListener('click', toggleMenu);

        // Close menu on link click
        links.forEach(l => {
          l.addEventListener('click', () => {
            if (isOpen) toggleMenu();
          });
        });
      }
    </script>
    {isHome && <SeasonalEffects />}
  </body>
</html>
